<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <%= render RubyUI::Card.new(class: "w-full max-w-md shadow-xl") do %>
    <%= render RubyUI::CardHeader.new(class: "space-y-3 text-center") do %>
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-primary text-primary-foreground shadow-sm">
        <i class="fas fa-clock text-xl"></i>
      </div>

      <div class="space-y-1">
        <%= render RubyUI::CardTitle.new(class: "text-2xl") do %>
          Entrar
        <% end %>

        <%= render RubyUI::CardDescription.new do %>
          Acesse sua conta do Smart Ponto
        <% end %>
      </div>
    <% end %>

    <%= render RubyUI::CardContent.new do %>
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
        <%= render RubyUI::FormField.new do %>
          <%= render RubyUI::FormFieldLabel.new(for: "#{resource_name}_email") do %>
            Email
          <% end %>
          <%= render RubyUI::Input.new(
                type: :email,
                id: "#{resource_name}_email",
                name: "#{resource_name}[email]",
                value: resource.email,
                autocomplete: "email",
                placeholder: "voce@empresa.com",
                required: true
              ) %>
        <% end %>

        <%= render RubyUI::FormField.new do %>
          <div class="flex items-center justify-between gap-4">
            <%= render RubyUI::FormFieldLabel.new(for: "#{resource_name}_password") do %>
              Senha
            <% end %>

            <%= link_to "Esqueceu sua senha?", new_password_path(resource_name), class: "text-sm text-muted-foreground hover:text-foreground transition-colors" %>
          </div>

          <%= render RubyUI::Input.new(
                type: :password,
                id: "#{resource_name}_password",
                name: "#{resource_name}[password]",
                autocomplete: "current-password",
                placeholder: "Digite sua senha",
                required: true
              ) %>
        <% end %>

        <% if devise_mapping.rememberable? %>
          <label for="<%= "#{resource_name}_remember_me" %>" class="flex items-center gap-3 text-sm text-muted-foreground">
            <%= render RubyUI::Checkbox.new(
                  id: "#{resource_name}_remember_me",
                  name: "#{resource_name}[remember_me]",
                  value: "1",
                  checked: resource.remember_me
                ) %>
            <span>Lembrar de mim</span>
          </label>
        <% end %>

        <%= render RubyUI::Button.new(type: :submit, class: "w-full") do %>
          Entrar
        <% end %>
      <% end %>

      <div class="mt-6 border-t pt-6 text-center text-sm text-muted-foreground">
        <span>Nao tem conta?</span>
        <%= link_to "Registre-se", new_registration_path(resource_name), class: "ml-1 font-medium text-foreground hover:text-primary transition-colors" %>
      </div>
    <% end %>
  <% end %>
</div>
