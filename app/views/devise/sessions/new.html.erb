<%= render RubyUI::Card.new(class: "w-full border-white/80 bg-white/92 shadow-[0_18px_45px_rgba(48,45,74,0.12)] backdrop-blur") do %>
  <%= render RubyUI::CardHeader.new(class: "space-y-4 px-6 pt-6 text-center sm:px-8 sm:pt-8") do %>
    <div class="space-y-4">
      <div class="mx-auto inline-flex items-center rounded-full bg-secondary px-3 py-1 text-xs font-medium tracking-[0.14em] text-secondary-foreground uppercase">
        Acesso seguro
      </div>

      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-primary text-primary-foreground shadow-sm">
        <i class="fas fa-clock text-xl"></i>
      </div>

      <div class="space-y-1">
        <%= render RubyUI::CardTitle.new(class: "text-2xl tracking-tight sm:text-[1.9rem]") do %>
          Entrar
        <% end %>

        <%= render RubyUI::CardDescription.new(class: "mx-auto max-w-sm text-sm leading-6 text-muted-foreground") do %>
          Entre para registrar seu ponto, acompanhar pendencias e manter sua rotina em dia.
        <% end %>
      </div>
    </div>
  <% end %>

  <%= render RubyUI::CardContent.new(class: "space-y-6 px-6 pb-6 sm:px-8 sm:pb-8") do %>
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
      <%= render RubyUI::FormField.new(class: "space-y-2") do %>
        <%= render RubyUI::FormFieldLabel.new(for: "#{resource_name}_email", class: "text-sm font-medium text-foreground") do %>
          Email
        <% end %>
        <%= render RubyUI::Input.new(
              type: :email,
              id: "#{resource_name}_email",
              name: "#{resource_name}[email]",
              value: resource.email,
              autocomplete: "email",
              placeholder: "voce@empresa.com",
              required: true,
              class: "h-11 border-border/80 bg-white shadow-none placeholder:text-muted-foreground/80"
            ) %>
      <% end %>

      <%= render RubyUI::FormField.new(class: "space-y-2") do %>
        <div class="flex items-center justify-between gap-4">
          <%= render RubyUI::FormFieldLabel.new(for: "#{resource_name}_password", class: "text-sm font-medium text-foreground") do %>
            Senha
          <% end %>

          <%= link_to "Esqueceu sua senha?", new_password_path(resource_name), class: "text-sm font-medium text-primary hover:text-primary/80 transition-colors" %>
        </div>

        <%= render RubyUI::Input.new(
              type: :password,
              id: "#{resource_name}_password",
              name: "#{resource_name}[password]",
              autocomplete: "current-password",
              placeholder: "Digite sua senha",
              required: true,
              class: "h-11 border-border/80 bg-white shadow-none placeholder:text-muted-foreground/80"
            ) %>
      <% end %>

      <% if devise_mapping.rememberable? %>
        <label for="<%= "#{resource_name}_remember_me" %>" class="flex items-center gap-3 rounded-xl bg-secondary/45 px-3 py-2.5 text-sm text-muted-foreground">
          <%= render RubyUI::Checkbox.new(
                id: "#{resource_name}_remember_me",
                name: "#{resource_name}[remember_me]",
                value: "1",
                checked: resource.remember_me
              ) %>
          <span>Lembrar de mim neste dispositivo</span>
        </label>
      <% end %>

      <%= render RubyUI::Button.new(type: :submit, class: "h-11 w-full text-sm font-semibold shadow-sm") do %>
        Entrar
      <% end %>
    <% end %>

    <div class="rounded-2xl border border-secondary/70 bg-secondary/35 px-4 py-3 text-center text-sm text-muted-foreground">
      <span>Nao tem conta?</span>
      <%= link_to "Registre-se", new_registration_path(resource_name), class: "ml-1 font-semibold text-primary hover:text-primary/80 transition-colors" %>
    </div>
  <% end %>
<% end %>
