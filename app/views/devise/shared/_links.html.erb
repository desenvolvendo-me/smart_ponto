<div class="flex flex-col items-center gap-2 text-sm">
  <%- if controller_name != 'sessions' %>
    <%= link_to "Entrar", new_session_path(resource_name), class: "font-semibold text-primary hover:text-primary/80 transition-colors" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <%= link_to "Criar conta", new_registration_path(resource_name), class: "font-semibold text-primary hover:text-primary/80 transition-colors" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <%= link_to "Esqueceu sua senha?", new_password_path(resource_name), class: "font-semibold text-primary hover:text-primary/80 transition-colors" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <%= link_to "Nao recebeu instrucoes de confirmacao?", new_confirmation_path(resource_name), class: "font-semibold text-primary hover:text-primary/80 transition-colors" %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <%= link_to "Nao recebeu instrucoes de desbloqueio?", new_unlock_path(resource_name), class: "font-semibold text-primary hover:text-primary/80 transition-colors" %>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <%= button_to "Entrar com #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "font-semibold text-primary hover:text-primary/80 transition-colors" %>
    <% end %>
  <% end %>
</div>
