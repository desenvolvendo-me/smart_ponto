<% if resource.errors.any? %>
  <%= render RubyUI::Alert.new(variant: :destructive, class: "mb-6 rounded-2xl border-destructive/20 bg-destructive/5 text-destructive shadow-none") do %>
    <i class="fas fa-exclamation-circle"></i>
    <div class="space-y-2">
      <%= render RubyUI::AlertTitle.new(class: "text-sm font-semibold") do %>
        <%= I18n.t("errors.messages.not_saved",
                   count: resource.errors.count,
                   resource: resource.class.model_name.human.downcase) %>
      <% end %>

      <%= render RubyUI::AlertDescription.new(class: "text-sm leading-6 text-destructive/90") do %>
        <ul class="list-disc space-y-1 pl-5">
          <% resource.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      <% end %>
    </div>
  <% end %>
<% end %>
