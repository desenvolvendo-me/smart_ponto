<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <%= render RubyUI::Card.new(class: "w-full max-w-md shadow-xl") do %>
    <%= render RubyUI::CardHeader.new(class: "space-y-3 text-center") do %>
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-primary text-primary-foreground shadow-sm">
        <i class="fas fa-user-plus text-xl"></i>
      </div>

      <div class="space-y-1">
        <%= render RubyUI::CardTitle.new(class: "text-2xl") do %>
          Criar Conta
        <% end %>

        <%= render RubyUI::CardDescription.new do %>
          Preencha os dados abaixo para se registrar
        <% end %>
      </div>
    <% end %>

    <%= render RubyUI::CardContent.new do %>
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <%= render RubyUI::FormField.new do %>
          <%= render RubyUI::FormFieldLabel.new(for: "#{resource_name}_name") do %>
            Nome
          <% end %>
          <%= render RubyUI::Input.new(
                id: "#{resource_name}_name",
                name: "#{resource_name}[name]",
                value: resource.name,
                autofocus: true,
                autocomplete: "name",
                placeholder: "Seu nome completo",
                required: true
              ) %>
        <% end %>

        <%= render RubyUI::FormField.new do %>
          <%= render RubyUI::FormFieldLabel.new(for: "#{resource_name}_employee_id") do %>
            ID de Funcionario
          <% end %>
          <%= render RubyUI::FormFieldHint.new do %>
            Opcional
          <% end %>
          <%= render RubyUI::Input.new(
                id: "#{resource_name}_employee_id",
                name: "#{resource_name}[employee_id]",
                value: resource.employee_id,
                placeholder: "Seu ID de funcionario, se aplicavel"
              ) %>
        <% end %>

        <%= render RubyUI::FormField.new do %>
          <%= render RubyUI::FormFieldLabel.new(for: "#{resource_name}_email") do %>
            Email
          <% end %>
          <%= render RubyUI::Input.new(
                type: :email,
                id: "#{resource_name}_email",
                name: "#{resource_name}[email]",
                value: resource.email,
                autocomplete: "email",
                placeholder: "voce@empresa.com",
                required: true
              ) %>
        <% end %>

        <%= render RubyUI::FormField.new do %>
          <%= render RubyUI::FormFieldLabel.new(for: "#{resource_name}_password") do %>
            Senha
          <% end %>
          <% if @minimum_password_length %>
            <%= render RubyUI::FormFieldHint.new do %>
              Minimo de <%= @minimum_password_length %> caracteres
            <% end %>
          <% end %>
          <%= render RubyUI::Input.new(
                type: :password,
                id: "#{resource_name}_password",
                name: "#{resource_name}[password]",
                autocomplete: "new-password",
                placeholder: "Crie uma senha",
                required: true
              ) %>
        <% end %>

        <%= render RubyUI::FormField.new do %>
          <%= render RubyUI::FormFieldLabel.new(for: "#{resource_name}_password_confirmation") do %>
            Confirme a senha
          <% end %>
          <%= render RubyUI::Input.new(
                type: :password,
                id: "#{resource_name}_password_confirmation",
                name: "#{resource_name}[password_confirmation]",
                autocomplete: "new-password",
                placeholder: "Confirme sua senha",
                required: true
              ) %>
        <% end %>

        <%= render RubyUI::Button.new(type: :submit, class: "w-full") do %>
          Registrar
        <% end %>
      <% end %>

      <div class="mt-6 border-t pt-6 text-center text-sm text-muted-foreground">
        <span>Ja tem uma conta?</span>
        <%= link_to "Entrar", new_session_path(resource_name), class: "ml-1 font-medium text-foreground hover:text-primary transition-colors" %>
      </div>
    <% end %>
  <% end %>
</div>
