<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <%= render RubyUI::Card.new(class: "w-full max-w-md shadow-xl") do %>
    <%= render RubyUI::CardHeader.new(class: "space-y-3 text-center") do %>
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-primary text-primary-foreground shadow-sm">
        <i class="fas fa-lock text-xl"></i>
      </div>

      <div class="space-y-1">
        <%= render RubyUI::CardTitle.new(class: "text-2xl") do %>
          Recuperar Senha
        <% end %>

        <%= render RubyUI::CardDescription.new do %>
          Enviaremos instrucoes para redefinir sua senha
        <% end %>
      </div>
    <% end %>

    <%= render RubyUI::CardContent.new do %>
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <%= render RubyUI::FormField.new do %>
          <%= render RubyUI::FormFieldLabel.new(for: "#{resource_name}_email") do %>
            Email
          <% end %>
          <%= render RubyUI::Input.new(
                type: :email,
                id: "#{resource_name}_email",
                name: "#{resource_name}[email]",
                value: resource.email,
                autofocus: true,
                autocomplete: "email",
                placeholder: "voce@empresa.com",
                required: true
              ) %>
        <% end %>

        <%= render RubyUI::Button.new(type: :submit, class: "w-full") do %>
          Enviar instrucoes
        <% end %>
      <% end %>

      <div class="mt-6 border-t pt-6 text-center text-sm text-muted-foreground">
        <%= link_to "Voltar para o login", new_session_path(resource_name), class: "font-medium text-foreground hover:text-primary transition-colors" %>
      </div>
    <% end %>
  <% end %>
</div>
