<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <%= render RubyUI::Card.new(class: "w-full max-w-md shadow-xl") do %>
    <%= render RubyUI::CardHeader.new(class: "space-y-3 text-center") do %>
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-primary text-primary-foreground shadow-sm">
        <i class="fas fa-key text-xl"></i>
      </div>

      <div class="space-y-1">
        <%= render RubyUI::CardTitle.new(class: "text-2xl") do %>
          Alterar Senha
        <% end %>

        <%= render RubyUI::CardDescription.new do %>
          Defina sua nova senha
        <% end %>
      </div>
    <% end %>

    <%= render RubyUI::CardContent.new do %>
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <%= render RubyUI::FormField.new do %>
          <%= render RubyUI::FormFieldLabel.new(for: "#{resource_name}_password") do %>
            Nova senha
          <% end %>
          <% if @minimum_password_length %>
            <%= render RubyUI::FormFieldHint.new do %>
              Minimo de <%= @minimum_password_length %> caracteres
            <% end %>
          <% end %>
          <%= render RubyUI::Input.new(
                type: :password,
                id: "#{resource_name}_password",
                name: "#{resource_name}[password]",
                autofocus: true,
                autocomplete: "new-password",
                placeholder: "Nova senha",
                required: true
              ) %>
        <% end %>

        <%= render RubyUI::FormField.new do %>
          <%= render RubyUI::FormFieldLabel.new(for: "#{resource_name}_password_confirmation") do %>
            Confirme a nova senha
          <% end %>
          <%= render RubyUI::Input.new(
                type: :password,
                id: "#{resource_name}_password_confirmation",
                name: "#{resource_name}[password_confirmation]",
                autocomplete: "new-password",
                placeholder: "Confirme a nova senha",
                required: true
              ) %>
        <% end %>

        <%= render RubyUI::Button.new(type: :submit, class: "w-full") do %>
          Alterar minha senha
        <% end %>
      <% end %>

      <div class="mt-6 border-t pt-6 text-center text-sm text-muted-foreground">
        <%= render "devise/shared/links" %>
      </div>
    <% end %>
  <% end %>
</div>
