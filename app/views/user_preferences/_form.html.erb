<%= form_with model: user_preference, url: user_preference_path, method: :patch, class: "space-y-5" do |f| %>
  <% if user_preference.errors.any? %>
    <section class="rounded-[22px] border border-red-200 bg-red-50 p-5 shadow-sm">
      <div class="flex items-start gap-3">
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-white text-red-600">
          <i class="fas fa-exclamation-circle"></i>
        </span>
        <div class="min-w-0">
          <h2 class="text-base font-semibold text-red-900">
            Revise <%= pluralize(user_preference.errors.count, "campo pendente", "campos pendentes") %>
          </h2>
          <ul class="mt-2 space-y-1 text-sm text-red-800">
            <% user_preference.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </section>
  <% end %>

  <section class="rounded-[24px] border border-border/70 bg-white p-5 shadow-sm">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <h2 class="text-xl font-semibold text-slate-950">Informações pessoais</h2>
        <p class="mt-1 text-sm leading-6 text-slate-600">
          Contato e preferências básicas da sua conta.
        </p>
      </div>
      <span class="inline-flex items-center rounded-full bg-secondary px-3 py-1 text-xs font-medium text-secondary-foreground">
        Perfil
      </span>
    </div>

    <div class="mt-5 grid gap-4 md:grid-cols-2">
      <div class="space-y-2">
        <%= f.label :phone_number, "Telefone", class: "text-sm font-medium text-slate-900" %>
        <%= f.telephone_field :phone_number, class: "flex h-11 w-full rounded-xl border border-border bg-white px-4 text-sm text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-indigo-300 focus:ring-2 focus:ring-indigo-100", placeholder: "(00) 00000-0000" %>
        <p class="text-xs leading-5 text-slate-500">Opcional para contato rápido.</p>
      </div>

      <div class="space-y-2">
        <%= f.label :secondary_email, "Email secundário", class: "text-sm font-medium text-slate-900" %>
        <%= f.email_field :secondary_email, class: "flex h-11 w-full rounded-xl border border-border bg-white px-4 text-sm text-slate-900 shadow-sm outline-none transition placeholder:text-slate-400 focus:border-indigo-300 focus:ring-2 focus:ring-indigo-100", placeholder: "seu-email@exemplo.com" %>
        <p class="text-xs leading-5 text-slate-500">Opcional para recuperação e notificações.</p>
      </div>

      <div class="space-y-2 md:col-span-2">
        <%= f.label :language, "Idioma", class: "text-sm font-medium text-slate-900" %>
        <%= f.select :language, [["Português (Brasil)", "pt-BR"], ["English", "en"]], {}, class: "flex h-11 w-full rounded-xl border border-border bg-white px-4 text-sm text-slate-900 shadow-sm outline-none transition focus:border-indigo-300 focus:ring-2 focus:ring-indigo-100" %>
      </div>
    </div>
  </section>

  <section class="rounded-[24px] border border-border/70 bg-white p-5 shadow-sm">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <h2 class="text-xl font-semibold text-slate-950">Visualização</h2>
        <p class="mt-1 text-sm leading-6 text-slate-600">
          Controle como datas, horas e tema aparecem no seu dia a dia.
        </p>
      </div>
      <span class="inline-flex items-center rounded-full bg-secondary px-3 py-1 text-xs font-medium text-secondary-foreground">
        Preferências
      </span>
    </div>

    <div class="mt-5 grid gap-4 md:grid-cols-2">
      <div class="space-y-3 md:col-span-2">
        <%= f.label :theme, "Tema", class: "text-sm font-medium text-slate-900" %>
        <div class="grid gap-3 sm:grid-cols-3">
          <% [["light", "Claro", "Uso diurno"], ["dark", "Escuro", "Pouca luz"], ["system", "Sistema", "Segue o dispositivo"]].each do |value, label, description| %>
            <label class="flex cursor-pointer flex-col gap-1.5 rounded-2xl border border-border bg-secondary/15 p-3 text-left transition hover:border-indigo-200 hover:bg-indigo-50/70 has-[:checked]:border-indigo-300 has-[:checked]:bg-indigo-50">
              <div class="flex items-center justify-between gap-3">
                <span class="text-sm font-medium text-slate-900"><%= label %></span>
                <%= f.radio_button :theme, value, class: "h-4 w-4 border-border text-indigo-600 focus:ring-indigo-200" %>
              </div>
              <p class="text-xs leading-5 text-slate-500"><%= description %></p>
            </label>
          <% end %>
        </div>
      </div>

      <div class="space-y-2">
        <%= f.label :date_format, "Formato de data", class: "text-sm font-medium text-slate-900" %>
        <%= f.select :date_format, [["DD/MM/AAAA", "DD/MM/AAAA"], ["MM/DD/AAAA", "MM/DD/AAAA"], ["AAAA-MM-DD", "AAAA-MM-DD"]], {}, class: "flex h-11 w-full rounded-xl border border-border bg-white px-4 text-sm text-slate-900 shadow-sm outline-none transition focus:border-indigo-300 focus:ring-2 focus:ring-indigo-100" %>
        <p class="text-xs leading-5 text-slate-500">Exemplo: <%= Time.current.strftime("%d/%m/%Y") %></p>
      </div>

      <div class="space-y-2">
        <%= f.label :time_format, "Formato de hora", class: "text-sm font-medium text-slate-900" %>
        <%= f.select :time_format, [["24h", "24h"], ["12h (AM/PM)", "12h"]], {}, class: "flex h-11 w-full rounded-xl border border-border bg-white px-4 text-sm text-slate-900 shadow-sm outline-none transition focus:border-indigo-300 focus:ring-2 focus:ring-indigo-100" %>
        <p class="text-xs leading-5 text-slate-500">Exemplo: <%= Time.current.strftime("%H:%M") %></p>
      </div>

      <div class="space-y-2 md:col-span-2">
        <%= f.label :first_day_of_week, "Primeiro dia da semana", class: "text-sm font-medium text-slate-900" %>
        <%= f.select :first_day_of_week, [["Segunda-feira", "monday"], ["Domingo", "sunday"]], {}, class: "flex h-11 w-full rounded-xl border border-border bg-white px-4 text-sm text-slate-900 shadow-sm outline-none transition focus:border-indigo-300 focus:ring-2 focus:ring-indigo-100" %>
      </div>
    </div>
  </section>

  <section class="rounded-[24px] border border-border/70 bg-white p-5 shadow-sm">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <h2 class="text-xl font-semibold text-slate-950">Assinatura</h2>
        <p class="mt-1 text-sm leading-6 text-slate-600">
          Defina a confirmação necessária ao assinar a folha de ponto.
        </p>
      </div>
      <span class="inline-flex items-center rounded-full bg-secondary px-3 py-1 text-xs font-medium text-secondary-foreground">
        Segurança
      </span>
    </div>

    <div class="mt-5 rounded-[20px] border border-border/70 bg-secondary/15 px-4 py-4">
      <label class="flex items-start gap-3">
        <%= f.check_box :require_password_on_sign, class: "mt-0.5 h-5 w-5 rounded border-border text-indigo-600 focus:ring-indigo-200" %>
        <span class="min-w-0">
          <span class="block text-sm font-medium text-slate-900">Exigir senha ao assinar folha de ponto</span>
          <span class="mt-1 block text-sm leading-6 text-slate-600">
            Adiciona uma confirmação extra antes da assinatura.
          </span>
          <span class="mt-2 inline-flex items-center rounded-full bg-indigo-100 px-3 py-1 text-xs font-medium text-indigo-700">
            Recomendado para uso corporativo
          </span>
        </span>
      </label>
    </div>
  </section>

  <section class="flex flex-col gap-3 rounded-[24px] border border-border/70 bg-white p-4 shadow-sm sm:flex-row sm:items-center sm:justify-between">
    <p class="text-sm leading-6 text-slate-600">
      As alterações são aplicadas à sua conta atual e passam a valer nos próximos acessos e relatórios.
    </p>

    <div class="flex flex-col gap-3 sm:flex-row">
      <%= link_to authenticated_root_path, class: "inline-flex items-center justify-center rounded-xl border border-border bg-white px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700" do %>
        Voltar
      <% end %>
      <%= f.submit "Salvar configurações", class: "inline-flex items-center justify-center rounded-xl bg-indigo-600 px-5 py-3 text-sm font-medium text-white shadow-sm transition hover:bg-indigo-700", data: { disable_with: "Salvando..." } %>
    </div>
  </section>
<% end %>
