<div class="mx-auto flex w-full max-w-5xl flex-col gap-5 px-4 py-6 sm:px-6 lg:px-8">
  <section class="overflow-hidden rounded-[24px] border border-border/70 bg-white shadow-sm">
    <div class="bg-gradient-to-r from-indigo-50 via-white to-sky-50 px-5 py-5 sm:px-7">
      <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-2xl space-y-2">
          <span class="inline-flex items-center gap-2 rounded-full border border-indigo-200 bg-white/80 px-3 py-1 text-[11px] font-medium uppercase tracking-[0.18em] text-indigo-700">
            Conta
          </span>
          <div class="space-y-1">
            <h1 class="text-2xl font-semibold tracking-tight text-slate-950 sm:text-[2rem]">Configurações do usuário</h1>
            <p class="text-sm leading-6 text-slate-600">
              Ajuste idioma, visualização e assinatura da folha de ponto em uma única tela.
            </p>
          </div>
        </div>

        <div class="rounded-2xl border border-indigo-100 bg-white/90 px-4 py-2.5 text-sm text-slate-600 shadow-sm">
          <p class="font-medium text-slate-900">Conta atual</p>
          <p class="mt-1"><%= current_user.email %></p>
        </div>
      </div>
    </div>
  </section>

  <%= render "form", user_preference: @user_preference %>
</div>
