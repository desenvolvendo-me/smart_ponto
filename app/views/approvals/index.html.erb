<div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div class="space-y-2">
      <%= link_to time_sheets_path, class: "inline-flex items-center gap-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground" do %>
        <i class="fas fa-arrow-left text-xs"></i>
        <span>Voltar</span>
      <% end %>

      <div class="space-y-2">
        <h1 class="text-2xl font-semibold tracking-tight text-foreground sm:text-[1.9rem]">
          Aprovações
        </h1>
        <p class="max-w-3xl text-sm leading-6 text-muted-foreground">
          Revise solicitações enviadas pela equipe, filtre por contexto e decida rapidamente o que aprovar ou rejeitar.
        </p>
      </div>
    </div>
  </div>

  <%= render RubyUI::Card.new(class: "border-white/80 bg-white/92 shadow-[0_18px_45px_rgba(48,45,74,0.08)]") do %>
    <%= render RubyUI::CardHeader.new(class: "space-y-2 px-6 pt-6 sm:px-8 sm:pt-8") do %>
      <%= render RubyUI::CardTitle.new(class: "text-lg tracking-tight text-foreground") do %>
        Filtros
      <% end %>
      <%= render RubyUI::CardDescription.new(class: "text-sm leading-6 text-muted-foreground") do %>
        Refine a lista por colaborador, justificativa ou funcao.
      <% end %>
    <% end %>

    <%= render RubyUI::CardContent.new(class: "px-6 pb-6 sm:px-8 sm:pb-8") do %>
      <%= form_with url: approvals_path, method: :get, class: "grid gap-4 lg:grid-cols-[minmax(0,1.6fr)_220px_auto]" do |f| %>
        <%= render RubyUI::FormField.new(class: "space-y-2") do %>
          <%= render RubyUI::FormFieldLabel.new(for: "search", class: "text-sm font-medium text-foreground") do %>
            Buscar por nome ou justificativa
          <% end %>
          <%= f.text_field :search,
                value: params[:search],
                id: "search",
                class: "flex h-11 w-full rounded-md border border-border/80 bg-white px-3 py-2 text-sm text-foreground shadow-none outline-none transition-[color,box-shadow] placeholder:text-muted-foreground/80 focus-visible:border-ring focus-visible:ring-2 focus-visible:ring-ring/50",
                placeholder: "Digite um termo para buscar..." %>
        <% end %>

        <%= render RubyUI::FormField.new(class: "space-y-2") do %>
          <%= render RubyUI::FormFieldLabel.new(for: "position", class: "text-sm font-medium text-foreground") do %>
            Funcao
          <% end %>
          <%= f.select :position,
                options_for_select([['Todas as funcoes', '']] + @positions.map { |p| [p, p] }, params[:position]),
                {},
                { id: "position", class: "flex h-11 w-full rounded-md border border-border/80 bg-white px-3 py-2 text-sm text-foreground shadow-none outline-none transition-[color,box-shadow] focus-visible:border-ring focus-visible:ring-2 focus-visible:ring-ring/50" } %>
        <% end %>

        <div class="flex flex-col gap-3 sm:flex-row lg:items-end lg:justify-end">
          <% if params[:search].present? || params[:position].present? %>
            <%= link_to approvals_path(tab: @current_tab), class: "inline-flex h-11 items-center justify-center rounded-md border border-border bg-white px-4 text-sm font-medium text-foreground transition-colors hover:bg-accent" do %>
              Limpar
            <% end %>
          <% end %>

          <%= render RubyUI::Button.new(type: :submit, class: "h-11 px-5 text-sm font-semibold shadow-sm") do %>
            Aplicar filtros
          <% end %>
        </div>

        <%= f.hidden_field :tab, value: @current_tab %>
      <% end %>
    <% end %>
  <% end %>

  <%= render RubyUI::Card.new(class: "border-white/80 bg-white/92 shadow-[0_18px_45px_rgba(48,45,74,0.08)] overflow-hidden", data: { controller: "tabs" }) do %>
    <div class="border-b border-border/70 bg-secondary/20 px-3 py-3 sm:px-4">
      <div class="grid grid-cols-2 gap-2">
        <%= link_to "#",
              data: { tab: "pending", action: "click->tabs#switch", tabs_target: "tab" },
              class: "inline-flex items-center justify-center gap-2 rounded-xl px-4 py-3 text-sm font-medium transition-colors #{@current_tab == 'pending' ? 'bg-white text-foreground shadow-sm ring-1 ring-border/70' : 'text-muted-foreground hover:bg-white/70 hover:text-foreground'}" do %>
          <i class="fas fa-clock text-xs"></i>
          <span>Pendentes</span>
          <span class="rounded-full bg-secondary px-2 py-0.5 text-xs font-semibold text-secondary-foreground"><%= @pending_count %></span>
        <% end %>

        <%= link_to "#",
              data: { tab: "history", action: "click->tabs#switch", tabs_target: "tab" },
              class: "inline-flex items-center justify-center gap-2 rounded-xl px-4 py-3 text-sm font-medium transition-colors #{@current_tab == 'history' ? 'bg-white text-foreground shadow-sm ring-1 ring-border/70' : 'text-muted-foreground hover:bg-white/70 hover:text-foreground'}" do %>
          <i class="fas fa-history text-xs"></i>
          <span>Historico</span>
        <% end %>
      </div>
    </div>

    <div data-tabs-target="content" data-tab="pending" class="<%= @current_tab == 'history' ? 'hidden' : '' %>">
      <% if @pending_sheets.empty? %>
        <div class="px-6 py-14 text-center sm:px-8">
          <div class="mx-auto mb-5 inline-flex h-16 w-16 items-center justify-center rounded-full bg-amber-100 text-amber-600">
            <i class="fas fa-inbox text-2xl"></i>
          </div>
          <h3 class="text-lg font-semibold text-foreground">Nenhuma solicitacao pendente</h3>
          <p class="mx-auto mt-2 max-w-md text-sm leading-6 text-muted-foreground">
            Todas as solicitacoes enviadas ja foram processadas. Quando novas aprovacoes chegarem, elas aparecerao aqui.
          </p>
        </div>
      <% else %>
        <div class="divide-y divide-border/70">
          <% @pending_sheets.each do |time_sheet| %>
            <%= render "approval_item", time_sheet: time_sheet %>
          <% end %>
        </div>

        <% if @pending_sheets.total_pages > 1 %>
          <div class="flex flex-col gap-4 border-t border-border/70 px-6 py-5 text-sm text-muted-foreground sm:px-8 lg:flex-row lg:items-center lg:justify-between">
            <p>
              Mostrando <span class="font-medium text-foreground"><%= @pending_sheets.offset_value + 1 %></span> a
              <span class="font-medium text-foreground"><%= [@pending_sheets.offset_value + @pending_sheets.limit_value, @pending_sheets.total_count].min %></span>
              de <span class="font-medium text-foreground"><%= @pending_sheets.total_count %></span> solicitacoes.
            </p>
            <%= paginate @pending_sheets, param_name: "pending_page" %>
          </div>
        <% end %>
      <% end %>
    </div>

    <div data-tabs-target="content" data-tab="history" class="<%= @current_tab != 'history' ? 'hidden' : '' %>">
      <% if @history_sheets.empty? %>
        <div class="px-6 py-14 text-center sm:px-8">
          <div class="mx-auto mb-5 inline-flex h-16 w-16 items-center justify-center rounded-full bg-secondary text-secondary-foreground">
            <i class="fas fa-history text-2xl"></i>
          </div>
          <h3 class="text-lg font-semibold text-foreground">Historico vazio</h3>
          <p class="mx-auto mt-2 max-w-md text-sm leading-6 text-muted-foreground">
            Nenhuma solicitacao foi aprovada ou rejeitada ainda. O historico aparecera aqui assim que as primeiras decisoes forem tomadas.
          </p>
        </div>
      <% else %>
        <div class="divide-y divide-border/70">
          <% @history_sheets.each do |time_sheet| %>
            <%= render "approval_item", time_sheet: time_sheet %>
          <% end %>
        </div>

        <% if @history_sheets.total_pages > 1 %>
          <div class="flex flex-col gap-4 border-t border-border/70 px-6 py-5 text-sm text-muted-foreground sm:px-8 lg:flex-row lg:items-center lg:justify-between">
            <p>
              Mostrando <span class="font-medium text-foreground"><%= @history_sheets.offset_value + 1 %></span> a
              <span class="font-medium text-foreground"><%= [@history_sheets.offset_value + @history_sheets.limit_value, @history_sheets.total_count].min %></span>
              de <span class="font-medium text-foreground"><%= @history_sheets.total_count %></span> solicitacoes.
            </p>
            <%= paginate @history_sheets, param_name: "history_page" %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
