<% daily_status = dashboard_daily_status_meta(@daily_summary) %>
<% weekly_status = dashboard_weekly_status_meta(@weekly_summary) %>
<% weekly_progress = [@weekly_summary[:completion_percentage], 100].min %>
<% daily_has_activity = dashboard_has_activity?(@daily_summary) %>

<div class="mx-auto flex w-full max-w-7xl flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
  <section class="overflow-hidden rounded-[24px] border border-border/70 bg-white shadow-sm">
    <div class="bg-gradient-to-r from-indigo-50 via-white to-sky-50 px-5 py-5 sm:px-7">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-2xl space-y-2">
          <span class="inline-flex items-center gap-2 rounded-full border border-indigo-200 bg-white/80 px-3 py-1 text-[11px] font-medium uppercase tracking-[0.18em] text-indigo-700">
            Painel diário
          </span>
          <div class="space-y-1">
            <h1 class="text-2xl font-semibold tracking-tight text-slate-950 sm:text-[2rem]">Meu dashboard</h1>
            <p class="max-w-xl text-sm leading-6 text-slate-600">
              <%= l(Date.current, format: :long) %>. Acompanhe sua jornada, veja o que precisa de atenção e avance sem sair desta página.
            </p>
          </div>
        </div>

        <div class="grid gap-3 sm:grid-cols-2">
          <%= link_to time_sheets_path, class: "inline-flex items-center justify-center gap-2 rounded-xl border border-border/70 bg-white px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700" do %>
            <i class="fas fa-list-ul text-indigo-500"></i>
            Ver registros
          <% end %>

          <%= button_to quick_register_time_entries_path(return_to: "dashboard"), method: :post, class: "inline-flex items-center justify-center gap-2 rounded-xl bg-indigo-600 px-4 py-3 text-sm font-medium text-white shadow-sm transition hover:bg-indigo-700" do %>
            <i class="fas fa-plus"></i>
            Registrar ponto
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <section class="grid gap-4 xl:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)]">
    <div class="grid gap-4 md:grid-cols-2">
      <article class="rounded-[22px] border border-border/70 bg-white p-5 shadow-sm">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-sm font-medium text-slate-500">Hoje</p>
            <h2 class="mt-1 text-base font-semibold text-slate-900">Horas trabalhadas</h2>
          </div>
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-indigo-50 text-indigo-600">
            <i class="fas fa-clock"></i>
          </span>
        </div>

        <div class="mt-5 flex items-end justify-between gap-4">
          <div>
            <p class="text-4xl font-semibold tracking-tight text-slate-950">
              <%= format_hours_minutes(@daily_summary[:worked_hours]) %>
            </p>
            <p class="mt-2 text-sm text-slate-500">
              Meta do dia: <strong class="font-medium text-slate-700"><%= number_with_precision(@daily_summary[:daily_goal], precision: 0) %>h 00min</strong>
            </p>
          </div>
          <span class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-sm font-medium <%= daily_status[:classes] %>">
            <i class="fas <%= daily_status[:icon] %>"></i>
            <%= daily_status[:label] %>
          </span>
        </div>

        <p class="mt-3 text-sm leading-6 text-slate-600"><%= daily_status[:description] %></p>
      </article>

      <article class="rounded-[22px] border border-border/70 bg-white p-5 shadow-sm">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-sm font-medium text-slate-500">Semana atual</p>
            <h2 class="mt-1 text-base font-semibold text-slate-900">Meta semanal</h2>
          </div>
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-sky-50 text-sky-600">
            <i class="fas fa-chart-line"></i>
          </span>
        </div>

        <div class="mt-5 flex items-end justify-between gap-4">
          <div>
            <p class="text-4xl font-semibold tracking-tight text-slate-950">
              <%= format_hours_minutes(@weekly_summary[:worked_hours]) %>
            </p>
            <p class="mt-2 text-sm text-slate-500">
              <%= @weekly_summary[:days_worked] %> dias registrados em <strong class="font-medium text-slate-700"><%= dashboard_period_label(@weekly_summary[:start_date], @weekly_summary[:end_date]) %></strong>
            </p>
          </div>
          <span class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-sm font-medium <%= weekly_status[:classes] %>">
            <i class="fas <%= weekly_status[:icon] %>"></i>
            <%= weekly_status[:label] %>
          </span>
        </div>

        <div class="mt-4 space-y-3">
          <div class="h-3 overflow-hidden rounded-full bg-slate-100">
            <div class="h-full rounded-full bg-indigo-600 transition-all duration-300" style="width: <%= weekly_progress %>%"></div>
          </div>
          <div class="flex items-center justify-between text-sm">
            <span class="text-slate-500">Meta: <%= number_with_precision(@weekly_summary[:weekly_goal], precision: 0) %>h</span>
            <span class="font-medium <%= weekly_status[:tone] %>"><%= @weekly_summary[:completion_percentage] %>% concluído</span>
          </div>
        </div>
      </article>
    </div>

    <article class="rounded-[22px] border border-border/70 bg-slate-950 p-5 text-white shadow-sm">
      <div class="flex items-start justify-between gap-3">
        <div>
          <p class="text-sm font-medium text-slate-300">Ritmo do dia</p>
          <h2 class="mt-1 text-base font-semibold">Próximo passo</h2>
        </div>
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white">
          <i class="fas fa-bolt"></i>
        </span>
      </div>

      <% if daily_has_activity %>
        <div class="mt-5 space-y-3">
          <div class="flex items-end justify-between gap-4 rounded-2xl border border-white/10 bg-white/5 p-4">
            <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
              <p class="text-xs uppercase tracking-[0.14em] text-slate-400">Último registro</p>
              <p class="mt-2 text-3xl font-semibold"><%= @daily_summary[:entries].last.time.strftime("%H:%M") %></p>
              <p class="mt-2 text-sm text-slate-300">
                <%= dashboard_entry_meta(@daily_summary[:entries].last)[:label] %>
              </p>
            </div>
            <div class="text-right">
              <p class="text-xs uppercase tracking-[0.14em] text-slate-400">Movimentos</p>
              <p class="mt-2 text-2xl font-semibold"><%= @daily_summary[:entries].size %></p>
            </div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
            <p class="text-xs uppercase tracking-[0.14em] text-slate-400">Estado atual</p>
            <p class="mt-2 text-sm font-medium text-white"><%= daily_status[:label] %></p>
          </div>
        </div>
      <% else %>
        <div class="mt-5 rounded-2xl border border-dashed border-white/15 bg-white/5 p-4">
          <p class="text-sm font-medium text-white">Seu dia ainda não começou.</p>
          <p class="mt-1 text-sm leading-6 text-slate-300">Faça o primeiro registro para liberar o acompanhamento de hoje.</p>
        </div>
      <% end %>
    </article>
  </section>

  <% if current_user.role == "gestor" && @pending_approvals_count.positive? %>
    <section class="rounded-[24px] border border-amber-200 bg-amber-50/60 p-6 shadow-sm">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div class="max-w-2xl">
          <div class="flex flex-wrap items-center gap-3">
            <h2 class="text-xl font-semibold text-slate-950">Fila de aprovações</h2>
            <span class="inline-flex items-center rounded-full bg-amber-100 px-3 py-1 text-sm font-medium text-amber-800">
              <%= @pending_approvals_count %> aguardando revisão
            </span>
          </div>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Priorize os registros enviados e use esta fila como atalho para destravar a equipe sem sair do dashboard.
          </p>
        </div>

        <%= link_to approvals_path, class: "inline-flex items-center justify-center gap-2 rounded-xl bg-amber-600 px-4 py-3 text-sm font-medium text-white transition hover:bg-amber-700" do %>
          <i class="fas fa-check-circle"></i>
          Revisar aprovações
        <% end %>
      </div>

      <div class="mt-5 grid gap-3 sm:grid-cols-3">
        <div class="rounded-2xl border border-amber-200 bg-white p-4">
          <p class="text-sm text-slate-500">Total na fila</p>
          <p class="mt-2 text-3xl font-semibold text-slate-950"><%= @pending_approvals_count %></p>
        </div>
        <div class="rounded-2xl border border-blue-200 bg-white p-4">
          <p class="text-sm text-slate-500">Enviados</p>
          <p class="mt-2 text-3xl font-semibold text-blue-700"><%= @pending_enviado_count %></p>
        </div>
        <div class="rounded-2xl border border-amber-200 bg-white p-4">
          <p class="text-sm text-slate-500">Pendentes</p>
          <p class="mt-2 text-3xl font-semibold text-amber-700"><%= @pending_pendente_count %></p>
        </div>
      </div>

      <div class="mt-6 space-y-4">
        <% @employees_with_pending.each do |employee| %>
          <div class="rounded-[22px] border border-white/80 bg-white p-5 shadow-sm">
            <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
              <div>
                <div class="flex flex-wrap items-center gap-3">
                  <h3 class="text-base font-semibold text-slate-950"><%= employee.name %></h3>
                  <span class="inline-flex items-center rounded-full bg-indigo-100 px-3 py-1 text-xs font-medium text-indigo-700">
                    <%= @pending_count_by_employee[employee.id] %> pendências
                  </span>
                </div>
                <p class="mt-1 text-sm text-slate-500"><%= [employee.position, employee.department].compact_blank.join(" • ") %></p>
              </div>

              <%= link_to approvals_path(search: employee.name), class: "inline-flex items-center gap-2 text-sm font-medium text-indigo-700 hover:text-indigo-800" do %>
                Ver histórico deste colaborador
                <i class="fas fa-arrow-right text-xs"></i>
              <% end %>
            </div>

            <div class="mt-4 grid gap-3 xl:grid-cols-2">
              <% @pending_by_employee[employee.id].each do |time_sheet| %>
                <% item = dashboard_pending_item_meta(time_sheet) %>
                <article class="rounded-2xl border border-border/70 bg-secondary/15 p-4">
                  <div class="flex flex-wrap items-start justify-between gap-3">
                    <div>
                      <p class="text-sm font-semibold text-slate-900"><%= l(time_sheet.date, format: :long) %></p>
                      <div class="mt-2 flex flex-wrap gap-2">
                        <% item[:alerts].each do |alert| %>
                          <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium <%= alert[:classes] %>">
                            <%= alert[:label] %>
                          </span>
                        <% end %>
                      </div>
                    </div>
                    <p class="text-sm font-medium text-slate-700"><%= item[:total] %></p>
                  </div>

                  <% if item[:justification] %>
                    <p class="mt-3 text-sm leading-6 text-slate-600"><%= item[:justification] %></p>
                  <% end %>

                  <div class="mt-4 flex flex-wrap gap-2">
                    <%= button_to approve_approval_path(time_sheet), method: :patch, class: "inline-flex items-center gap-2 rounded-xl bg-green-600 px-3 py-2 text-sm font-medium text-white transition hover:bg-green-700", form: { data: { turbo_confirm: "Aprovar este registro?" } } do %>
                      <i class="fas fa-check"></i>
                      Aprovar
                    <% end %>

                    <%= button_to reject_approval_path(time_sheet), method: :patch, class: "inline-flex items-center gap-2 rounded-xl border border-red-200 bg-white px-3 py-2 text-sm font-medium text-red-700 transition hover:bg-red-50", form: { data: { turbo_confirm: "Rejeitar este registro?" } } do %>
                      <i class="fas fa-times"></i>
                      Rejeitar
                    <% end %>
                  </div>
                </article>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  <% elsif current_user.role != "gestor" && @pending_count.positive? %>
    <section class="rounded-[24px] border border-amber-200 bg-amber-50/60 p-6 shadow-sm">
      <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
        <div class="max-w-2xl">
          <div class="flex flex-wrap items-center gap-3">
            <h2 class="text-xl font-semibold text-slate-950">Itens que exigem ação</h2>
            <span class="inline-flex items-center rounded-full bg-amber-100 px-3 py-1 text-sm font-medium text-amber-800">
              <%= @pending_count %> pendentes
            </span>
          </div>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Resolva os dias em aberto para manter o espelho do ponto pronto para envio e aprovação.
          </p>
        </div>
      </div>

      <div class="mt-5 grid gap-3 sm:grid-cols-3">
        <div class="rounded-2xl border border-amber-200 bg-white p-4">
          <p class="text-sm text-slate-500">Total</p>
          <p class="mt-2 text-3xl font-semibold text-slate-950"><%= @pending_count %></p>
        </div>
        <div class="rounded-2xl border border-amber-200 bg-white p-4">
          <p class="text-sm text-slate-500">Pendentes</p>
          <p class="mt-2 text-3xl font-semibold text-amber-700"><%= @pending_pendente_count %></p>
        </div>
        <div class="rounded-2xl border border-blue-200 bg-white p-4">
          <p class="text-sm text-slate-500">Enviados</p>
          <p class="mt-2 text-3xl font-semibold text-blue-700"><%= @pending_enviado_count %></p>
        </div>
      </div>

      <div class="mt-6 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
        <% @pending_items.each do |time_sheet| %>
          <% meta = time_sheet_status_meta(time_sheet) %>
          <article class="rounded-[22px] border border-white/80 bg-white p-5 shadow-sm">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-base font-semibold text-slate-950"><%= l(time_sheet.date, format: :long) %></p>
                <p class="mt-1 text-sm text-slate-500"><%= time_sheet.complete? ? "Dia completo" : "Dia ainda incompleto" %></p>
              </div>
              <span class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-medium <%= meta[:classes] %>">
                <i class="fas <%= meta[:icon] %>"></i>
                <%= meta[:label] %>
              </span>
            </div>

            <%= link_to time_sheet_path(time_sheet), class: "mt-5 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-amber-600 px-4 py-3 text-sm font-medium text-white transition hover:bg-amber-700" do %>
              <i class="fas fa-eye"></i>
              Abrir registro
            <% end %>
          </article>
        <% end %>
      </div>
    </section>
  <% end %>

  <section class="grid gap-6 xl:grid-cols-[minmax(0,1.08fr)_minmax(0,0.92fr)]">
    <article class="rounded-[24px] border border-border/70 bg-white p-6 shadow-sm">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h2 class="text-xl font-semibold text-slate-950">Dias recentes</h2>
          <p class="mt-1 text-sm text-slate-500">Resumo rápido para revisar o que já foi concluído e o que ainda exige atenção.</p>
        </div>
        <% if @recent_time_sheets.any? %>
          <%= link_to time_sheets_path, class: "inline-flex items-center gap-2 text-sm font-medium text-indigo-700 hover:text-indigo-800" do %>
            Ver histórico completo
            <i class="fas fa-arrow-right text-xs"></i>
          <% end %>
        <% end %>
      </div>

      <% if @recent_time_sheets.any? %>
        <div class="mt-5 space-y-3">
          <% @recent_time_sheets.each do |time_sheet| %>
            <% meta = dashboard_recent_time_sheet_meta(time_sheet) %>
            <div class="rounded-[22px] border p-4 <%= meta[:card_classes] %>">
              <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-center gap-2">
                    <p class="text-base font-semibold text-slate-950"><%= l(time_sheet.date, format: :long) %></p>
                    <span class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-medium <%= meta[:status][:classes] %>">
                      <i class="fas <%= meta[:status][:icon] %>"></i>
                      <%= meta[:status][:label] %>
                    </span>
                    <% if meta[:justification] %>
                      <span class="inline-flex items-center gap-2 rounded-full px-3 py-1 text-xs font-medium <%= meta[:justification][:classes] %>">
                        <i class="fas <%= meta[:justification][:icon] %>"></i>
                        <%= meta[:justification][:label] %>
                      </span>
                    <% end %>
                  </div>

                  <div class="mt-3 flex flex-wrap items-center gap-3 text-sm">
                    <span class="font-medium <%= meta[:total][:tone] %>">
                      <i class="fas fa-clock mr-1.5 text-slate-400"></i>
                      <%= format_hours(time_sheet.total_hours) %>
                    </span>
                    <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium <%= meta[:total][:badge_classes] %>">
                      <%= meta[:total][:badge] %>
                    </span>
                  </div>

                  <p class="mt-3 text-sm leading-6 <%= meta[:attention] ? 'text-slate-700' : 'text-slate-600' %>"><%= meta[:next_step][:description] %></p>
                </div>

                <%= link_to time_sheet_path(time_sheet), class: "inline-flex items-center justify-center gap-2 rounded-xl border border-border/70 bg-white px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700" do %>
                  <i class="fas <%= meta[:action_icon] %>"></i>
                  <%= meta[:action_label] %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="mt-5 rounded-2xl border border-dashed border-border bg-secondary/15 p-5 text-sm leading-6 text-slate-600">
          Você ainda não possui dias registrados. Assim que começar a usar o ponto, o resumo recente ficará visível aqui.
        </div>
      <% end %>
    </article>

    <article class="rounded-[24px] border border-border/70 bg-white p-6 shadow-sm">
      <div class="flex items-center justify-between gap-3">
        <div>
          <h2 class="text-xl font-semibold text-slate-950">Movimentos de hoje</h2>
          <p class="mt-1 text-sm text-slate-500">Entradas e saídas registradas ao longo do dia.</p>
        </div>
        <span class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-green-50 text-green-600">
          <i class="fas fa-clipboard-list"></i>
        </span>
      </div>

      <% if daily_has_activity %>
        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          <% @daily_summary[:entries].each_with_index do |entry, index| %>
            <% entry_meta = dashboard_entry_meta(entry) %>
            <div class="rounded-2xl border border-border/70 bg-secondary/15 p-4">
              <div class="flex items-start justify-between gap-3">
                <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-indigo-50 text-indigo-600">
                  <i class="fas <%= entry_meta[:icon] %>"></i>
                </span>
                <span class="text-xs font-medium uppercase tracking-[0.12em] text-slate-400">#<%= index + 1 %></span>
              </div>
              <p class="mt-4 text-sm font-medium text-slate-600"><%= entry_meta[:label] %></p>
              <p class="mt-1 text-2xl font-semibold text-slate-950"><%= entry.time.strftime("%H:%M") %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="mt-5 rounded-2xl border border-dashed border-border bg-secondary/15 p-4 text-sm leading-6 text-slate-600">
          Nenhum movimento registrado hoje. O primeiro ponto do dia vai aparecer aqui assim que for salvo.
        </div>
      <% end %>
    </article>
  </section>
</div>
