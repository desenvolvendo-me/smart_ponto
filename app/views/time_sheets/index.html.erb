<% is_weekend_today = Date.current.saturday? || Date.current.sunday? %>
<% can_register_today = can_register_on_date?(current_user, Date.current) %>

<div class="mx-auto flex w-full max-w-6xl flex-col gap-6">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div class="space-y-2">
      <div class="flex items-center gap-3">
        <% if request.referer && request.referer != request.original_url %>
          <%= link_to :back, class: "inline-flex h-9 w-9 items-center justify-center rounded-full border border-border bg-white text-muted-foreground transition-colors hover:bg-accent hover:text-foreground" do %>
            <i class="fas fa-arrow-left text-sm"></i>
          <% end %>
        <% end %>

        <div class="space-y-1">
          <h1 class="text-2xl font-semibold tracking-tight text-foreground sm:text-[1.9rem]">Meu Ponto</h1>
          <p class="max-w-3xl text-sm leading-6 text-muted-foreground">
            Consulte suas jornadas, acompanhe pendências e envie registros completos para aprovação.
          </p>
        </div>
      </div>

      <div class="inline-flex w-fit items-center gap-2 rounded-full bg-secondary/80 px-3 py-1.5 text-sm font-medium text-secondary-foreground">
        <i class="fas fa-calendar-week text-xs"></i>
        <span><%= @time_sheets.total_count %> dia<%= "s" unless @time_sheets.total_count == 1 %> listado<%= "s" unless @time_sheets.total_count == 1 %></span>
      </div>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
      <%= link_to export_form_time_sheets_path, class: "inline-flex h-11 items-center justify-center gap-2 rounded-md border border-border/80 bg-white/70 px-4 text-sm font-medium text-muted-foreground transition-colors hover:bg-white hover:text-foreground" do %>
        <i class="fas fa-file-export text-sm"></i>
        Exportar
      <% end %>

      <div class="relative group">
        <%= button_to quick_register_time_entries_path(return_to: "list"),
            method: :post,
            disabled: !can_register_today,
            class: registration_button_classes(current_user, Date.current, "inline-flex h-11 items-center justify-center rounded-md bg-primary px-5 text-sm font-semibold text-primary-foreground shadow-sm transition hover:bg-primary/90") do %>
          <i class="fas fa-plus mr-2 text-sm"></i>
          Registrar ponto
        <% end %>

        <% if is_weekend_today && !can_register_today %>
          <div class="absolute right-0 top-full z-10 mt-2 w-64 rounded-xl bg-foreground px-3 py-2 text-sm text-background opacity-0 shadow-lg transition-opacity duration-200 pointer-events-none group-hover:opacity-100">
            <%= weekend_registration_tooltip %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="inline-flex w-fit items-center gap-1 rounded-xl bg-secondary/70 p-1">
    <%= link_to time_sheets_path, class: "inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-medium transition #{current_page?(time_sheets_path) ? 'bg-white text-foreground shadow-sm ring-1 ring-border/70' : 'text-muted-foreground hover:bg-white/70 hover:text-foreground'}" do %>
      <i class="fas fa-list text-sm"></i>
      Lista
    <% end %>

    <%= link_to calendar_time_sheets_path, class: "inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-medium transition #{current_page?(calendar_time_sheets_path) ? 'bg-white text-foreground shadow-sm ring-1 ring-border/70' : 'text-muted-foreground hover:bg-white/70 hover:text-foreground'}" do %>
      <i class="fas fa-calendar-alt text-sm"></i>
      Calendário
    <% end %>
  </div>

  <% if @time_sheets.empty? %>
    <%= render RubyUI::Card.new(class: "border-white/80 bg-white/92 shadow-[0_18px_45px_rgba(48,45,74,0.08)]") do %>
      <%= render RubyUI::CardContent.new(class: "px-6 py-14 text-center sm:px-8") do %>
        <div class="mx-auto mb-5 inline-flex h-16 w-16 items-center justify-center rounded-full bg-secondary text-secondary-foreground">
          <i class="fas fa-clock text-2xl"></i>
        </div>
        <h2 class="text-xl font-semibold tracking-tight text-foreground">Nenhum registro de ponto</h2>
        <p class="mx-auto mt-3 max-w-md text-sm leading-6 text-muted-foreground">
          Você ainda não possui registros. Comece registrando o primeiro ponto do dia para acompanhar sua jornada por aqui.
        </p>
        <div class="mt-6 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <div class="relative group">
            <%= button_to quick_register_time_entries_path(return_to: "list"),
                method: :post,
                disabled: !can_register_today,
                class: registration_button_classes(current_user, Date.current, "inline-flex h-11 items-center justify-center rounded-md bg-primary px-5 text-sm font-semibold text-primary-foreground shadow-sm transition hover:bg-primary/90") do %>
              <i class="fas fa-plus mr-2 text-sm"></i>
              Registrar ponto
            <% end %>

            <% if is_weekend_today && !can_register_today %>
              <div class="absolute left-1/2 top-full z-10 mt-2 w-64 -translate-x-1/2 rounded-xl bg-foreground px-3 py-2 text-sm text-background opacity-0 shadow-lg transition-opacity duration-200 pointer-events-none group-hover:opacity-100">
                <%= weekend_registration_tooltip %>
              </div>
            <% end %>
          </div>

          <%= link_to export_form_time_sheets_path, class: "inline-flex h-11 items-center justify-center gap-2 rounded-md border border-border bg-white px-4 text-sm font-medium text-foreground transition-colors hover:bg-accent" do %>
            <i class="fas fa-file-export text-sm"></i>
            Exportar
          <% end %>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <div class="space-y-4">
      <% @time_sheets.each do |time_sheet| %>
        <% status = time_sheet_status_meta(time_sheet) %>
        <% relative_label = time_sheet_relative_day_label(time_sheet.date) %>
        <% total_meta = time_sheet_total_meta(time_sheet) %>
        <% justification_meta = time_sheet_justification_meta(time_sheet) %>
        <% day_meta = time_sheet_day_meta(time_sheet) %>
        <% next_step = time_sheet_next_step_meta(time_sheet) %>
        <% entries = time_sheet.time_entries.order(:time) %>
        <% show_actions = time_sheet.status == "completo" && !time_sheet.approval_status.in?(%w[aprovado enviado]) %>
        <% show_footer_copy = !day_meta[:resolved] %>
        <% compact_card = day_meta[:resolved] %>

        <%= render RubyUI::Card.new(class: "overflow-hidden #{day_meta[:card_classes]} shadow-[0_18px_45px_rgba(48,45,74,0.08)]") do %>
          <%= render RubyUI::CardContent.new(class: "px-5 #{compact_card ? 'py-4' : 'py-5'} sm:px-7") do %>
            <div class="flex flex-col gap-3.5">
              <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                <div class="flex items-start gap-3">
                  <div class="flex h-11 w-11 flex-none items-center justify-center rounded-full bg-secondary text-secondary-foreground">
                    <i class="fas fa-calendar-alt text-sm"></i>
                  </div>

                  <div class="space-y-1.5">
                    <div class="flex flex-wrap items-center gap-2">
                      <h2 class="text-[1.35rem] font-semibold tracking-tight text-foreground">
                        <%= time_sheet.date.strftime("%d/%m/%Y") %>
                      </h2>
                      <% if relative_label.present? %>
                        <span class="<%= relative_label[1] %> inline-flex items-center rounded-full px-2.5 py-1 text-xs font-medium">
                          <%= relative_label[0] %>
                        </span>
                      <% end %>
                    </div>

                    <div class="flex flex-wrap items-center gap-2 text-sm">
                      <span class="<%= status[:classes] %> inline-flex items-center gap-2 rounded-full px-2.5 py-1 font-medium">
                        <i class="fas <%= status[:icon] %> text-xs"></i>
                        <%= status[:label] %>
                      </span>

                      <% if time_sheet.signature? %>
                        <span class="inline-flex items-center gap-2 rounded-full border border-green-200 bg-green-50 px-2.5 py-1 text-sm font-medium text-green-700">
                          <i class="fas fa-signature text-xs"></i>
                          Assinado digitalmente
                        </span>
                      <% end %>

                      <% if justification_meta.present? %>
                        <span class="<%= justification_meta[:classes] %> inline-flex items-center gap-2 rounded-full px-2.5 py-1 text-sm font-medium">
                          <i class="fas <%= justification_meta[:icon] %> text-xs"></i>
                          <%= justification_meta[:label] %>
                        </span>
                      <% end %>
                    </div>
                  </div>
                </div>

                <div class="rounded-2xl border px-4 <%= compact_card ? 'py-2.5 lg:min-w-[230px]' : 'py-3 lg:min-w-[250px]' %> <%= day_meta[:summary_classes] %>">
                  <p class="text-xs font-semibold uppercase tracking-[0.12em] text-muted-foreground">Resumo da jornada</p>
                  <div class="mt-1.5 flex items-center gap-2">
                    <span class="<%= total_meta[:tone] %> text-lg font-semibold">
                      <%= format_hours(time_sheet.total_hours) %>
                    </span>
                    <span class="<%= total_meta[:badge_classes] %> rounded-full px-2.5 py-1 text-xs font-medium">
                      <%= total_meta[:badge] %>
                    </span>
                  </div>
                  <p class="mt-1.5 text-sm text-muted-foreground">
                    <%= total_meta[:hint] %>
                  </p>
                </div>
              </div>

              <% if day_meta[:attention] %>
                <div class="rounded-2xl border px-4 py-3 text-sm <%= day_meta[:guidance_classes] %>">
                  <p class="font-semibold"><%= day_meta[:guidance_label] %></p>
                  <p class="mt-1 leading-6"><%= day_meta[:guidance_text] %></p>
                </div>
              <% end %>

              <% if time_sheet.time_entries.where(entry_type: "entrada").first&.observation.present? %>
                <div class="rounded-2xl border border-border/70 bg-secondary/20 px-4 py-3 text-sm text-muted-foreground">
                  <p class="mb-1 text-xs font-semibold uppercase tracking-[0.12em] text-muted-foreground">Observação do dia</p>
                  <div class="flex items-start gap-2">
                    <i class="fas fa-comment-alt mt-0.5 text-xs text-primary"></i>
                    <span><%= time_sheet.time_entries.where(entry_type: "entrada").first.observation %></span>
                  </div>
                </div>
              <% end %>

              <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
                <% entries.each do |entry| %>
                  <% entry_meta = time_sheet_entry_meta(entry) %>
                  <% entry_status = time_sheet_entry_status_meta(entry) %>
                  <div class="rounded-2xl border border-border/70 bg-white px-4 <%= compact_card ? 'py-3' : 'py-3.5' %>">
                    <p class="inline-flex items-center gap-2 text-sm font-medium text-muted-foreground">
                      <i class="fas <%= entry_meta[:icon] %> text-xs <%= entry_meta[:icon_classes] %>"></i>
                      <%= entry_meta[:label] %>
                    </p>
                    <p class="mt-2 text-[2rem] font-semibold tracking-tight text-foreground">
                      <%= entry.time.strftime("%H:%M") %>
                    </p>
                    <span class="<%= entry_status[:classes] %> mt-2 inline-flex items-center gap-2 rounded-full px-2.5 py-1 text-xs font-medium">
                      <i class="fas <%= entry_status[:icon] %> text-[10px]"></i>
                      <%= entry_status[:label] %>
                    </span>
                  </div>
                <% end %>

                <% (4 - entries.size).times do %>
                  <div class="rounded-2xl border border-dashed border-border/80 bg-secondary/10 px-4 <%= compact_card ? 'py-3' : 'py-3.5' %>">
                    <p class="text-sm font-medium text-muted-foreground">Pendente</p>
                    <p class="mt-2 text-[2rem] font-semibold tracking-tight text-muted-foreground/60">--:--</p>
                    <span class="mt-2 inline-flex items-center gap-2 rounded-full bg-muted px-2.5 py-1 text-xs font-medium text-muted-foreground">
                      <i class="fas fa-hourglass-half text-[10px]"></i>
                      Aguardando
                    </span>
                  </div>
                <% end %>
              </div>

              <% if show_footer_copy || show_actions %>
                <div class="flex flex-col gap-3 border-t border-border/70 pt-3 lg:flex-row lg:items-end lg:justify-between">
                  <% if show_footer_copy %>
                    <div class="space-y-1">
                      <p class="text-sm font-medium text-foreground"><%= next_step[:title] %></p>
                      <p class="text-sm text-muted-foreground"><%= next_step[:description] %></p>
                    </div>
                  <% else %>
                    <div></div>
                  <% end %>

                  <div class="flex flex-wrap gap-2">
                    <% if show_actions %>
                    <% if time_sheet.justification.present? %>
                      <%= link_to time_sheet_path(time_sheet), class: "inline-flex h-10 items-center justify-center gap-2 rounded-md border border-border bg-white px-4 text-sm font-medium text-foreground transition-colors hover:bg-accent" do %>
                        <i class="fas fa-eye text-sm"></i>
                        Ver justificativa
                      <% end %>
                    <% elsif !time_sheet.within_tolerance? %>
                      <%= link_to time_sheet_path(time_sheet), class: "inline-flex h-10 items-center justify-center gap-2 rounded-md bg-amber-500 px-4 text-sm font-medium text-white transition-colors hover:bg-amber-600" do %>
                        <i class="fas fa-plus-circle text-sm"></i>
                        Adicionar justificativa
                      <% end %>
                    <% end %>

                    <% if time_sheet.within_tolerance? || time_sheet.justification.present? %>
                      <%= button_to submit_for_approval_time_sheet_path(time_sheet, return_to: "list"), method: :post, class: "inline-flex h-10 items-center justify-center rounded-md bg-primary px-4 text-sm font-semibold text-primary-foreground shadow-sm transition hover:bg-primary/90" do %>
                        <i class="fas fa-paper-plane mr-2 text-sm"></i>
                        Enviar para aprovação
                      <% end %>
                    <% end %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <div class="py-2">
      <%= paginate @time_sheets %>
    </div>
  <% end %>
</div>
