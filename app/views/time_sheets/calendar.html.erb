<% is_weekend_today = Date.current.saturday? || Date.current.sunday? %>
<% can_register_today = can_register_on_date?(current_user, Date.current) %>
<% month_summary = calendar_month_summary(@time_sheets, @date) %>

<div class="mx-auto flex w-full max-w-7xl flex-col gap-6">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div class="space-y-2">
      <div class="flex items-center gap-3">
        <% if request.referer && request.referer != request.original_url %>
          <%= link_to :back, class: "inline-flex h-9 w-9 items-center justify-center rounded-full border border-border bg-white text-muted-foreground transition-colors hover:bg-accent hover:text-foreground" do %>
            <i class="fas fa-arrow-left text-sm"></i>
          <% end %>
        <% end %>

        <div class="space-y-1">
          <h1 class="text-2xl font-semibold tracking-tight text-foreground sm:text-[1.9rem]">Calendário de Ponto</h1>
          <p class="max-w-3xl text-sm leading-6 text-muted-foreground">
            Visualize sua jornada por dia, navegue pelo mês e acesse rapidamente dias com registros ou pendências.
          </p>
        </div>
      </div>

      <div class="inline-flex w-fit items-center gap-2 rounded-full bg-secondary/80 px-3 py-1.5 text-sm font-medium text-secondary-foreground">
        <i class="fas fa-calendar-week text-xs"></i>
        <span><%= l(@date, format: "%B %Y").capitalize %></span>
      </div>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
      <%= link_to export_form_time_sheets_path, class: "inline-flex h-11 items-center justify-center gap-2 rounded-md border border-border/80 bg-white/70 px-4 text-sm font-medium text-muted-foreground transition-colors hover:bg-white hover:text-foreground" do %>
        <i class="fas fa-file-export text-sm"></i>
        Exportar
      <% end %>

      <div class="relative group">
        <%= button_to quick_register_time_entries_path(return_to: "calendar"),
            method: :post,
            disabled: !can_register_today,
            class: registration_button_classes(current_user, Date.current, "inline-flex h-11 items-center justify-center rounded-md bg-primary px-5 text-sm font-semibold text-primary-foreground shadow-sm transition hover:bg-primary/90") do %>
          <i class="fas fa-plus mr-2 text-sm"></i>
          Registrar ponto
        <% end %>

        <% if is_weekend_today && !can_register_today %>
          <div class="absolute right-0 top-full z-10 mt-2 w-64 rounded-xl bg-foreground px-3 py-2 text-sm text-background opacity-0 shadow-lg transition-opacity duration-200 pointer-events-none group-hover:opacity-100">
            <%= weekend_registration_tooltip %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="inline-flex w-fit items-center gap-1 rounded-xl bg-secondary/70 p-1">
    <%= link_to time_sheets_path, class: "inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-medium transition #{current_page?(time_sheets_path) ? 'bg-white text-foreground shadow-sm ring-1 ring-border/70' : 'text-muted-foreground hover:bg-white/70 hover:text-foreground'}" do %>
      <i class="fas fa-list text-sm"></i>
      Lista
    <% end %>

    <%= link_to calendar_time_sheets_path, class: "inline-flex items-center gap-2 rounded-lg px-4 py-2 text-sm font-medium transition #{current_page?(calendar_time_sheets_path) ? 'bg-white text-foreground shadow-sm ring-1 ring-border/70' : 'text-muted-foreground hover:bg-white/70 hover:text-foreground'}" do %>
      <i class="fas fa-calendar-alt text-sm"></i>
      Calendário
    <% end %>
  </div>

  <%= render RubyUI::Card.new(class: "overflow-hidden border-white/80 bg-white/92 shadow-[0_18px_45px_rgba(48,45,74,0.08)]") do %>
    <%= render RubyUI::CardContent.new(class: "px-5 py-5 sm:px-7 sm:py-6") do %>
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex items-center gap-3">
          <%= link_to calendar_time_sheets_path(month: @date.prev_month.month, year: @date.prev_month.year),
                class: "inline-flex h-10 w-10 items-center justify-center rounded-full border border-border bg-white text-foreground transition-colors hover:bg-accent" do %>
            <i class="fas fa-chevron-left text-sm"></i>
          <% end %>

          <div class="space-y-1">
            <h2 class="text-[1.75rem] font-semibold tracking-tight text-foreground">
              <%= l(@date, format: "%B %Y").capitalize %>
            </h2>
            <p class="text-sm text-muted-foreground">
              <%= month_summary[:total_days] %> dia<%= "s" unless month_summary[:total_days] == 1 %> com registro neste mês
            </p>
          </div>

          <%= link_to calendar_time_sheets_path(month: @date.next_month.month, year: @date.next_month.year),
                class: "inline-flex h-10 w-10 items-center justify-center rounded-full border border-border bg-white text-foreground transition-colors hover:bg-accent" do %>
            <i class="fas fa-chevron-right text-sm"></i>
          <% end %>
        </div>

        <div class="flex flex-wrap gap-2">
          <% if @date.month != Date.current.month || @date.year != Date.current.year %>
            <%= link_to calendar_time_sheets_path, class: "inline-flex h-10 items-center justify-center gap-2 rounded-md border border-border bg-white px-4 text-sm font-medium text-foreground transition-colors hover:bg-accent" do %>
              <i class="fas fa-calendar-day text-sm"></i>
              Mês atual
            <% end %>
          <% end %>

          <span class="inline-flex h-10 items-center rounded-md bg-secondary/70 px-4 text-sm text-secondary-foreground">
            Selecione um dia para ver detalhes ou registrar ponto.
          </span>
        </div>
      </div>
    <% end %>
  <% end %>

  <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_280px]">
    <div class="space-y-4">
      <%= render RubyUI::Card.new(class: "overflow-hidden border-white/80 bg-white/92 shadow-[0_18px_45px_rgba(48,45,74,0.08)] hidden md:block") do %>
        <div class="grid grid-cols-7 border-b border-border/70 bg-secondary/20">
          <% ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'].each_with_index do |day, index| %>
            <div class="px-3 py-3 text-center text-sm font-medium <%= index == 0 || index == 6 ? 'text-red-600' : 'text-foreground' %>">
              <%= day %>
            </div>
          <% end %>
        </div>

        <div class="grid grid-cols-7">
          <% @calendar_days.each do |day| %>
            <% time_sheet = @time_sheets_by_date[day] %>
            <% day_meta = calendar_day_meta(day, @date, time_sheet) %>
            <% entry_pairs = calendar_entry_pair(time_sheet) %>

            <div class="relative min-h-[136px] border-b border-r border-border/70 p-2.5 transition-colors hover:bg-secondary/20 last:border-r-0 <%= day_meta[:base_classes] %>">
              <% if day_meta[:accent_classes].present? %>
                <div class="absolute inset-x-0 top-0 h-1 <%= day_meta[:accent_classes] %>"></div>
              <% end %>

              <div class="flex items-start justify-between gap-2">
                <div class="flex items-center gap-2">
                  <span class="<%= day_meta[:day_number_classes] %>"><%= day.day %></span>
                  <% if day_meta[:today] %>
                    <span class="rounded-full bg-indigo-100 px-2 py-0.5 text-xs font-medium text-indigo-700">Hoje</span>
                  <% end %>
                </div>

                <% if time_sheet && day_meta[:in_month] %>
                  <span class="<%= day_meta[:status][:classes] %> inline-flex h-2.5 w-2.5 rounded-full border-0 p-0"></span>
                <% end %>
              </div>

              <% if day_meta[:in_month] %>
                <div class="mt-2.5 space-y-2">
                  <% if time_sheet %>
                    <%= link_to time_sheet_path(time_sheet), class: "block rounded-xl border border-border/70 bg-white/90 p-2 transition hover:bg-white hover:shadow-sm" do %>
                      <div class="space-y-1">
                        <% entry_pairs.first(2).each do |pair| %>
                          <div class="flex items-center justify-between rounded-lg bg-secondary/20 px-2 py-1 text-[11px] font-medium text-foreground">
                            <span><%= pair[:entry] %></span>
                            <span class="text-muted-foreground">→</span>
                            <span><%= pair[:exit] %></span>
                          </div>
                        <% end %>
                      </div>

                      <div class="mt-1.5 flex items-center justify-between gap-2 text-[11px]">
                        <span class="font-medium text-foreground"><%= day_meta[:total_hours] %></span>
                        <span class="<%= day_meta[:status][:classes] %> inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-medium">
                          <%= day_meta[:status][:label] %>
                        </span>
                      </div>
                    <% end %>
                  <% elsif day <= Date.current %>
                    <% if day_meta[:empty_today] %>
                      <%= link_to new_time_entry_path(date: day, return_to: "calendar"),
                          class: registration_button_classes(current_user, day, "inline-flex w-full items-center justify-center gap-2 rounded-lg bg-indigo-50 px-2.5 py-2 text-xs font-medium text-indigo-700 transition hover:bg-indigo-100") do %>
                        <i class="fas fa-plus-circle text-[11px]"></i>
                        Registrar
                      <% end %>
                    <% else %>
                      <div class="rounded-xl border border-dashed border-border/70 bg-white/70 px-2.5 py-2 text-center">
                        <p class="text-[11px] font-medium text-muted-foreground">Sem registro</p>
                        <%= link_to new_time_entry_path(date: day, return_to: "calendar"),
                            class: registration_button_classes(current_user, day, "mt-1 inline-flex items-center gap-1 text-[11px] font-medium text-indigo-700 transition hover:text-indigo-800") do %>
                          <i class="fas fa-plus-circle text-[10px]"></i>
                          Registrar
                        <% end %>
                      </div>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="space-y-3 md:hidden">
        <% @calendar_days.each do |day| %>
          <% next unless day.month == @date.month %>
          <% time_sheet = @time_sheets_by_date[day] %>
          <% day_meta = calendar_day_meta(day, @date, time_sheet) %>
          <% entry_pairs = calendar_entry_pair(time_sheet) %>

          <%= render RubyUI::Card.new(class: "overflow-hidden #{day_meta[:today] ? 'border-indigo-200 bg-indigo-50/40' : 'border-white/80 bg-white/92'} shadow-[0_12px_30px_rgba(48,45,74,0.08)]") do %>
            <%= render RubyUI::CardContent.new(class: "px-5 py-4") do %>
              <div class="flex items-start justify-between gap-3">
                <div class="space-y-1">
                  <div class="flex items-center gap-2">
                    <span class="<%= day_meta[:day_number_classes] %>"><%= l(day, format: "%d/%m") %></span>
                    <% if day_meta[:today] %>
                      <span class="rounded-full bg-indigo-100 px-2 py-0.5 text-xs font-medium text-indigo-700">Hoje</span>
                    <% end %>
                  </div>
                  <p class="text-sm text-muted-foreground"><%= l(day, format: "%A").capitalize %></p>
                </div>

                <% if time_sheet %>
                  <span class="<%= day_meta[:status][:classes] %> inline-flex items-center gap-2 rounded-full px-2.5 py-1 text-xs font-medium">
                    <%= day_meta[:status][:label] %>
                  </span>
                <% end %>
              </div>

              <% if time_sheet %>
                <div class="mt-4 space-y-3">
                  <div class="grid grid-cols-2 gap-2">
                    <% entry_pairs.first(2).each do |pair| %>
                      <div class="rounded-xl border border-border/70 bg-white px-3 py-2.5 text-sm">
                        <div class="text-xs font-medium text-muted-foreground">Entrada / saída</div>
                        <div class="mt-1 font-semibold text-foreground"><%= pair[:entry] %> <span class="text-muted-foreground">→</span> <%= pair[:exit] %></div>
                      </div>
                    <% end %>
                  </div>

                  <div class="flex items-center justify-between rounded-xl bg-secondary/20 px-3 py-2.5 text-sm">
                    <span class="text-muted-foreground">Total do dia</span>
                    <span class="font-semibold text-foreground"><%= day_meta[:total_hours] %></span>
                  </div>

                  <%= link_to time_sheet_path(time_sheet), class: "inline-flex h-10 w-full items-center justify-center gap-2 rounded-md border border-border bg-white text-sm font-medium text-foreground transition-colors hover:bg-accent" do %>
                    <i class="fas fa-eye text-sm"></i>
                    Ver detalhes
                  <% end %>
                </div>
              <% elsif day <= Date.current %>
                <div class="mt-4">
                  <%= link_to new_time_entry_path(date: day, return_to: "calendar"),
                      class: registration_button_classes(current_user, day, "inline-flex h-10 w-full items-center justify-center gap-2 rounded-md bg-secondary/70 text-sm font-medium text-secondary-foreground transition hover:bg-secondary") do %>
                    <i class="fas fa-plus-circle text-sm"></i>
                    Registrar ponto
                  <% end %>
                </div>
              <% else %>
                <div class="mt-4 rounded-xl bg-secondary/20 px-3 py-2.5 text-sm text-muted-foreground">
                  Dia futuro sem registro disponível.
                </div>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>

    <div class="space-y-4">
      <%= render RubyUI::Card.new(class: "border-white/80 bg-white/92 shadow-[0_18px_45px_rgba(48,45,74,0.08)]") do %>
        <%= render RubyUI::CardContent.new(class: "px-5 py-5 sm:px-6") do %>
          <div class="space-y-3">
            <div class="space-y-1">
              <h3 class="text-lg font-semibold tracking-tight text-foreground">Legenda</h3>
              <p class="text-sm text-muted-foreground">Use as cores para localizar exceções mais rápido.</p>
            </div>

            <div class="space-y-2">
              <div class="flex items-start gap-3 rounded-xl bg-secondary/20 px-3 py-2.5">
                <span class="mt-1 h-2.5 w-2.5 rounded-full bg-amber-400"></span>
                <div>
                  <p class="text-sm font-medium text-foreground">Pendente</p>
                  <p class="text-xs text-muted-foreground">Ainda não enviado ou fora da tolerância.</p>
                </div>
              </div>

              <div class="flex items-start gap-3 rounded-xl bg-secondary/20 px-3 py-2.5">
                <span class="mt-1 h-2.5 w-2.5 rounded-full bg-blue-400"></span>
                <div>
                  <p class="text-sm font-medium text-foreground">Enviado</p>
                  <p class="text-xs text-muted-foreground">Aguardando aprovação ou análise.</p>
                </div>
              </div>

              <div class="flex items-start gap-3 rounded-xl bg-secondary/20 px-3 py-2.5">
                <span class="mt-1 h-2.5 w-2.5 rounded-full bg-green-400"></span>
                <div>
                  <p class="text-sm font-medium text-foreground">Aprovado</p>
                  <p class="text-xs text-muted-foreground">Dia concluído sem pendências.</p>
                </div>
              </div>

              <div class="flex items-start gap-3 rounded-xl bg-secondary/20 px-3 py-2.5">
                <span class="mt-1 h-2.5 w-2.5 rounded-full bg-red-400"></span>
                <div>
                  <p class="text-sm font-medium text-foreground">Rejeitado</p>
                  <p class="text-xs text-muted-foreground">Requer revisão ou correção.</p>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>

      <%= render RubyUI::Card.new(class: "border-white/80 bg-white/92 shadow-[0_18px_45px_rgba(48,45,74,0.08)]") do %>
        <%= render RubyUI::CardContent.new(class: "px-5 py-5 sm:px-6") do %>
          <div class="space-y-4">
            <div class="space-y-1">
              <h3 class="text-lg font-semibold tracking-tight text-foreground">Resumo do mês</h3>
              <p class="text-sm text-muted-foreground">Uma visão rápida do volume e do estado dos registros neste período.</p>
            </div>

            <div>
              <div class="mb-2 flex items-center justify-between text-sm">
                <span class="text-muted-foreground">Progresso do mês</span>
                <span class="font-medium text-foreground"><%= month_summary[:completion_percentage] %>%</span>
              </div>
              <div class="h-2.5 rounded-full bg-secondary">
                <div class="h-2.5 rounded-full bg-primary" style="width: <%= month_summary[:completion_percentage] %>%"></div>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div class="rounded-2xl bg-secondary/30 px-4 py-3">
                <div class="text-xs font-medium uppercase tracking-[0.1em] text-muted-foreground">Dias trabalhados</div>
                <div class="mt-1 text-2xl font-semibold text-foreground">
                  <%= month_summary[:total_days] %>
                  <span class="text-xs font-medium text-muted-foreground">/ <%= month_summary[:business_days] %> úteis</span>
                </div>
              </div>

              <div class="rounded-2xl bg-secondary/30 px-4 py-3">
                <div class="text-xs font-medium uppercase tracking-[0.1em] text-muted-foreground">Total de horas</div>
                <div class="mt-1 text-2xl font-semibold text-foreground"><%= month_summary[:total_hours] %>h</div>
              </div>
            </div>

            <div class="space-y-1">
              <div class="flex items-center justify-between rounded-xl px-3 py-2 text-sm hover:bg-secondary/20">
                <span class="flex items-center gap-2 text-foreground"><span class="h-2.5 w-2.5 rounded-full bg-amber-400"></span>Pendentes</span>
                <span class="font-medium text-foreground"><%= month_summary[:pending_count] %></span>
              </div>
              <div class="flex items-center justify-between rounded-xl px-3 py-2 text-sm hover:bg-secondary/20">
                <span class="flex items-center gap-2 text-foreground"><span class="h-2.5 w-2.5 rounded-full bg-blue-400"></span>Enviados</span>
                <span class="font-medium text-foreground"><%= month_summary[:sent_count] %></span>
              </div>
              <div class="flex items-center justify-between rounded-xl px-3 py-2 text-sm hover:bg-secondary/20">
                <span class="flex items-center gap-2 text-foreground"><span class="h-2.5 w-2.5 rounded-full bg-green-400"></span>Aprovados</span>
                <span class="font-medium text-foreground"><%= month_summary[:approved_count] %></span>
              </div>
              <div class="flex items-center justify-between rounded-xl px-3 py-2 text-sm hover:bg-secondary/20">
                <span class="flex items-center gap-2 text-foreground"><span class="h-2.5 w-2.5 rounded-full bg-red-400"></span>Rejeitados</span>
                <span class="font-medium text-foreground"><%= month_summary[:rejected_count] %></span>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
