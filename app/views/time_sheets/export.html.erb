<div data-controller="export"
     data-export-preview-url-value="<%= export_preview_time_sheets_path %>"
     class="mx-auto flex w-full max-w-7xl flex-col gap-6 px-4 py-6 sm:px-6 lg:px-8">
  <% preview_time_sheets = @preview_time_sheets || current_user.time_sheets.order(date: :desc) %>
  <% preview_count = preview_time_sheets.count %>
  <% start_date_value = params[:start_date] || Date.current.beginning_of_month.strftime("%Y-%m-%d") %>
  <% end_date_value = params[:end_date] || Date.current.strftime("%Y-%m-%d") %>

  <section class="overflow-hidden rounded-[24px] border border-border/70 bg-white shadow-sm">
    <div class="bg-gradient-to-r from-indigo-50 via-white to-sky-50 px-5 py-4 sm:px-6">
      <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-3xl space-y-2">
          <div class="flex items-center gap-3">
            <%= link_to time_sheets_path, class: "inline-flex h-10 w-10 items-center justify-center rounded-full border border-border bg-white text-slate-600 transition hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700" do %>
              <i class="fas fa-arrow-left text-sm"></i>
            <% end %>
            <p class="text-xs font-medium uppercase tracking-[0.18em] text-indigo-700">Exportação</p>
          </div>

          <div class="space-y-1">
            <h1 class="text-2xl font-semibold tracking-tight text-slate-950 sm:text-[2rem]">Exportar registros</h1>
            <p class="text-sm leading-6 text-slate-600">
              Escolha o período, confirme a prévia e baixe o recorte desejado.
            </p>
          </div>
        </div>

        <div class="rounded-2xl border border-indigo-100 bg-white/90 px-4 py-3 text-sm text-slate-600 shadow-sm">
          <p class="font-medium text-slate-900">Recorte atual</p>
          <p class="mt-1">Baixe somente o que aparece na prévia abaixo.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="grid gap-6 xl:grid-cols-[minmax(0,0.92fr)_minmax(0,1.08fr)]">
    <div class="space-y-6">
      <section class="rounded-[24px] border border-border/70 bg-white p-5 shadow-sm">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <h2 class="text-xl font-semibold text-slate-950">Configurar exportação</h2>
            <p class="mt-1 text-sm leading-6 text-slate-600">
              Defina o recorte antes de gerar o arquivo.
            </p>
          </div>
        </div>

        <%= form_with(url: export_time_sheets_path, method: :get, class: "mt-5 space-y-5",
                      data: { export_target: "form", action: "submit->export#submit" }) do |form| %>
          <div class="flex flex-wrap gap-2">
            <button type="button"
                    class="inline-flex items-center rounded-full border border-border bg-white px-3 py-1.5 text-xs font-medium text-slate-700 transition hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700"
                    data-action="export#applyCurrentMonth">
              Mês atual
            </button>
            <button type="button"
                    class="inline-flex items-center rounded-full border border-border bg-white px-3 py-1.5 text-xs font-medium text-slate-700 transition hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700"
                    data-action="export#applyPreviousMonth">
              Mês anterior
            </button>
            <button type="button"
                    class="inline-flex items-center rounded-full border border-border bg-white px-3 py-1.5 text-xs font-medium text-slate-700 transition hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700"
                    data-action="export#applyLast7Days">
              Últimos 7 dias
            </button>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <div class="space-y-2">
              <%= form.label :start_date, "Data inicial", class: "text-sm font-medium text-slate-900" %>
              <%= form.date_field :start_date,
                  value: start_date_value,
                  class: "flex h-11 w-full rounded-xl border border-border bg-white px-4 text-sm text-slate-900 shadow-sm outline-none transition focus:border-indigo-300 focus:ring-2 focus:ring-indigo-100",
                  data: { export_target: "startDate", action: "change->export#filterChanged" } %>
            </div>

            <div class="space-y-2">
              <%= form.label :end_date, "Data final", class: "text-sm font-medium text-slate-900" %>
              <%= form.date_field :end_date,
                  value: end_date_value,
                  class: "flex h-11 w-full rounded-xl border border-border bg-white px-4 text-sm text-slate-900 shadow-sm outline-none transition focus:border-indigo-300 focus:ring-2 focus:ring-indigo-100",
                  data: { export_target: "endDate", action: "change->export#filterChanged" } %>
            </div>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            <div class="space-y-2">
              <%= form.label :status, "Status de aprovação", class: "text-sm font-medium text-slate-900" %>
              <%= form.select :status,
                  [["Todos", ""], ["Pendente", "pendente"], ["Enviado", "enviado"], ["Aprovado", "aprovado"], ["Rejeitado", "rejeitado"]],
                  {},
                  class: "flex h-11 w-full rounded-xl border border-border bg-white px-4 text-sm text-slate-900 shadow-sm outline-none transition focus:border-indigo-300 focus:ring-2 focus:ring-indigo-100",
                  data: { action: "change->export#filterChanged" } %>
            </div>

            <div class="space-y-2">
              <%= form.label :complete, "Completude", class: "text-sm font-medium text-slate-900" %>
              <%= form.select :complete,
                  [["Todos", ""], ["Completos", "completo"], ["Incompletos", "incompleto"]],
                  {},
                  class: "flex h-11 w-full rounded-xl border border-border bg-white px-4 text-sm text-slate-900 shadow-sm outline-none transition focus:border-indigo-300 focus:ring-2 focus:ring-indigo-100",
                  data: { action: "change->export#filterChanged" } %>
            </div>
          </div>

          <div data-export-target="formMessage"
               class="hidden rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
          </div>

          <div class="space-y-3">
            <%= form.label :format, "Formato do arquivo", class: "text-sm font-medium text-slate-900" %>
            <div class="grid gap-3 sm:grid-cols-2">
              <label class="flex cursor-pointer flex-col gap-1.5 rounded-2xl border border-border bg-secondary/15 p-4 transition hover:border-indigo-200 hover:bg-indigo-50/70 has-[:checked]:border-indigo-300 has-[:checked]:bg-indigo-50">
                <div class="flex items-center justify-between gap-3">
                  <span class="text-sm font-medium text-slate-900">CSV</span>
                  <%= form.radio_button :format, "csv", checked: true,
                      class: "h-4 w-4 border-border text-indigo-600 focus:ring-indigo-200",
                      data: { export_target: "csvRadio" } %>
                </div>
                <p class="text-xs leading-5 text-slate-500">Mais simples para abrir e compartilhar rapidamente.</p>
              </label>

              <label class="flex cursor-pointer flex-col gap-1.5 rounded-2xl border border-border bg-secondary/15 p-4 transition hover:border-indigo-200 hover:bg-indigo-50/70 has-[:checked]:border-indigo-300 has-[:checked]:bg-indigo-50">
                <div class="flex items-center justify-between gap-3">
                  <span class="text-sm font-medium text-slate-900">Excel</span>
                  <%= form.radio_button :format, "excel",
                      class: "h-4 w-4 border-border text-indigo-600 focus:ring-indigo-200",
                      data: { export_target: "excelRadio" } %>
                </div>
                <p class="text-xs leading-5 text-slate-500">Melhor para edição. Se Excel não estiver disponível, o sistema gera CSV.</p>
              </label>
            </div>
          </div>

          <div class="flex flex-col gap-3 rounded-[20px] border border-border/70 bg-secondary/15 px-4 py-4 text-sm text-slate-600">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
              <p>O download será gerado exatamente com o recorte confirmado na prévia.</p>
              <span data-export-target="summary" class="inline-flex items-center rounded-full bg-white px-3 py-1 text-xs font-medium text-slate-700 shadow-sm">
                <%= preview_count %> registros no recorte atual
              </span>
            </div>

            <div class="flex flex-col gap-3 sm:flex-row">
              <button type="button"
                      class="inline-flex items-center justify-center rounded-xl border border-border bg-white px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700"
                      data-action="export#resetFilters">
                Limpar filtros
              </button>

              <%= link_to time_sheets_path, class: "inline-flex items-center justify-center rounded-xl border border-border bg-white px-4 py-3 text-sm font-medium text-slate-700 transition hover:border-indigo-200 hover:bg-indigo-50 hover:text-indigo-700" do %>
                Cancelar
              <% end %>

              <%= form.button type: "submit",
                  class: "inline-flex items-center justify-center gap-2 rounded-xl bg-indigo-600 px-5 py-3 text-sm font-medium text-white shadow-sm transition hover:bg-indigo-700 disabled:cursor-not-allowed disabled:bg-slate-300",
                  data: { export_target: "submitButton" } do %>
                <i class="fas fa-file-export text-sm"></i>
                Exportar registros
              <% end %>
            </div>
          </div>
        <% end %>
      </section>
    </div>

    <section class="rounded-[24px] border border-border/70 bg-white p-5 shadow-sm">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
        <div>
          <h2 class="text-xl font-semibold text-slate-950">Prévia dos dados</h2>
          <p class="mt-1 text-sm leading-6 text-slate-600">
            A lista reage aos filtros e mostra o recorte atual antes do download.
          </p>
        </div>
        <span data-export-target="previewStateBadge" class="inline-flex items-center rounded-full bg-secondary px-3 py-1 text-xs font-medium text-secondary-foreground">
          Pronta para revisar
        </span>
      </div>

      <div class="mt-4 flex items-center justify-between gap-3 rounded-2xl border border-border/70 bg-secondary/15 px-4 py-3 text-sm text-slate-600">
        <p data-export-target="previewHint">Confira alguns registros antes de baixar o arquivo final.</p>
        <span data-export-target="previewCount" class="inline-flex items-center rounded-full bg-white px-3 py-1 text-xs font-medium text-slate-700 shadow-sm">
          <%= preview_count %> linhas
        </span>
      </div>

      <div class="mt-4 overflow-hidden rounded-[22px] border border-border/70">
        <div class="hidden bg-secondary/30 px-4 py-3 text-xs font-medium uppercase tracking-[0.14em] text-slate-500 lg:grid lg:grid-cols-[1.2fr_repeat(4,minmax(0,0.8fr))_0.8fr_1fr] lg:gap-3">
          <span>Data</span>
          <span>Entrada 1</span>
          <span>Saída 1</span>
          <span>Entrada 2</span>
          <span>Saída 2</span>
          <span>Total</span>
          <span>Status</span>
        </div>

        <div data-export-target="previewTbody" class="max-h-[560px] divide-y divide-border/70 overflow-y-auto bg-white">
          <% preview_time_sheets.each do |sheet| %>
            <%
              entries = sheet.time_entries.order(:time)
              times = entries.map { |e| e.time.strftime("%H:%M") }
              while times.length < 4
                times << "-"
              end
              badge_classes = case sheet.approval_status
                              when "aprovado" then "bg-green-100 text-green-800"
                              when "enviado" then "bg-blue-100 text-blue-800"
                              when "rejeitado" then "bg-red-100 text-red-800"
                              else "bg-gray-100 text-gray-800"
                              end
              badge_label = case sheet.approval_status
                            when "aprovado" then "Aprovado"
                            when "enviado" then "Enviado"
                            when "rejeitado" then "Rejeitado"
                            else "Pendente"
                            end
            %>
            <div class="grid gap-3 px-4 py-4 lg:grid-cols-[1.2fr_repeat(4,minmax(0,0.8fr))_0.8fr_1fr] lg:items-center">
              <div>
                <p class="text-sm font-medium text-slate-900"><%= sheet.date.strftime("%d/%m/%Y") %></p>
                <p class="mt-1 text-xs text-slate-500 lg:hidden">Referência do registro</p>
              </div>
              <div class="grid grid-cols-2 gap-3 text-sm text-slate-600 lg:contents">
                <div>
                  <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-slate-400 lg:hidden">Entrada 1</p>
                  <p><%= times[0] %></p>
                </div>
                <div>
                  <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-slate-400 lg:hidden">Saída 1</p>
                  <p><%= times[1] %></p>
                </div>
                <div>
                  <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-slate-400 lg:hidden">Entrada 2</p>
                  <p><%= times[2] %></p>
                </div>
                <div>
                  <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-slate-400 lg:hidden">Saída 2</p>
                  <p><%= times[3] %></p>
                </div>
              </div>
              <div>
                <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-slate-400 lg:hidden">Total</p>
                <p class="text-sm font-medium text-slate-700"><%= sheet.total_hours.to_f %>h</p>
              </div>
              <div>
                <p class="text-[11px] font-medium uppercase tracking-[0.14em] text-slate-400 lg:hidden">Status</p>
                <span class="inline-flex rounded-full px-2.5 py-1 text-xs font-medium <%= badge_classes %>"><%= badge_label %></span>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <details class="mt-4 rounded-2xl border border-border/70 bg-secondary/10">
        <summary class="cursor-pointer list-none px-4 py-3 text-sm font-medium text-slate-900">
          O que vai no arquivo
        </summary>
        <div class="grid gap-3 border-t border-border/70 px-4 py-4 sm:grid-cols-2">
          <% [["Data do registro", "Dia de referência do ponto"], ["Entradas e saídas", "Horários registrados no período"], ["Total de horas", "Soma da jornada do dia"], ["Status de aprovação", "Situação atual do registro"]].each do |title, description| %>
            <div class="rounded-2xl border border-border/70 bg-white p-4">
              <p class="text-sm font-medium text-slate-900"><%= title %></p>
              <p class="mt-1 text-xs leading-5 text-slate-500"><%= description %></p>
            </div>
          <% end %>
        </div>
      </details>
    </section>
  </section>
</div>
