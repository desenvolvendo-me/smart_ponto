<% active_filters = [params[:search], params[:department], params[:position], params[:weekend_status]].count(&:present?) %>

<div class="mx-auto flex w-full max-w-6xl flex-col gap-5" data-controller="weekend-toggle">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div class="space-y-2">
      <%= link_to time_sheets_path, class: "inline-flex items-center gap-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground" do %>
        <i class="fas fa-arrow-left text-xs"></i>
        <span>Voltar</span>
      <% end %>

      <div class="space-y-2">
        <h1 class="text-2xl font-semibold tracking-tight text-foreground sm:text-[1.9rem]">
          Gestao de Equipe
        </h1>
        <p class="max-w-3xl text-sm leading-6 text-muted-foreground">
          Ajuste permissoes de registro em fim de semana e acompanhe rapidamente os dados principais da equipe.
        </p>
      </div>
    </div>

    <div class="inline-flex items-center gap-2 self-start rounded-full bg-secondary/80 px-3 py-1.5 text-sm font-medium text-secondary-foreground lg:self-auto">
      <i class="fas fa-users text-xs"></i>
      <span><%= @users.total_count %> integrante<%= "s" unless @users.total_count == 1 %></span>
    </div>
  </div>

  <%= render RubyUI::Card.new(class: "border-white/80 bg-white/92 shadow-[0_18px_45px_rgba(48,45,74,0.08)]") do %>
    <%= render RubyUI::CardContent.new(class: "px-6 py-6 sm:px-8 sm:py-7") do %>
      <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <div class="space-y-1">
          <h2 class="text-base font-semibold tracking-tight text-foreground">Filtros</h2>
          <p class="text-sm text-muted-foreground">
            Encontre rapidamente quem precisa de ajuste ou revisao.
          </p>
        </div>

        <% if active_filters.positive? %>
          <span class="inline-flex items-center gap-2 self-start rounded-full bg-secondary px-3 py-1 text-xs font-medium text-secondary-foreground sm:self-auto">
            <i class="fas fa-filter text-[10px]"></i>
            <%= active_filters %> filtro<%= "s" unless active_filters == 1 %> ativo<%= "s" unless active_filters == 1 %>
          </span>
        <% end %>
      </div>

      <%= form_with url: manager_team_members_path, method: :get, class: "grid gap-3 xl:grid-cols-[minmax(0,1.5fr)_170px_170px_200px_auto]" do |f| %>
        <%= render RubyUI::FormField.new(class: "space-y-2") do %>
          <%= render RubyUI::FormFieldLabel.new(for: "search", class: "text-sm font-medium text-foreground") do %>
            Buscar por nome, email ou ID
          <% end %>
          <%= f.text_field :search,
                value: params[:search],
                id: "search",
                class: "flex h-11 w-full rounded-md border border-border/80 bg-white px-3 py-2 text-sm text-foreground shadow-none outline-none transition-[color,box-shadow] placeholder:text-muted-foreground/80 focus-visible:border-ring focus-visible:ring-2 focus-visible:ring-ring/50",
                placeholder: "Digite para buscar..." %>
        <% end %>

        <%= render RubyUI::FormField.new(class: "space-y-2") do %>
          <%= render RubyUI::FormFieldLabel.new(for: "department", class: "text-sm font-medium text-foreground") do %>
            Departamento
          <% end %>
          <%= f.select :department,
                options_for_select([["Todos", ""]] + @departments.map { |d| [d, d] }, params[:department]),
                {},
                { id: "department", class: "flex h-11 w-full rounded-md border border-border/80 bg-white px-3 py-2 text-sm text-foreground shadow-none outline-none transition-[color,box-shadow] focus-visible:border-ring focus-visible:ring-2 focus-visible:ring-ring/50" } %>
        <% end %>

        <%= render RubyUI::FormField.new(class: "space-y-2") do %>
          <%= render RubyUI::FormFieldLabel.new(for: "position", class: "text-sm font-medium text-foreground") do %>
            Funcao
          <% end %>
          <%= f.select :position,
                options_for_select([["Todas", ""]] + @positions.map { |p| [p, p] }, params[:position]),
                {},
                { id: "position", class: "flex h-11 w-full rounded-md border border-border/80 bg-white px-3 py-2 text-sm text-foreground shadow-none outline-none transition-[color,box-shadow] focus-visible:border-ring focus-visible:ring-2 focus-visible:ring-ring/50" } %>
        <% end %>

        <%= render RubyUI::FormField.new(class: "space-y-2") do %>
          <%= render RubyUI::FormFieldLabel.new(for: "weekend_status", class: "text-sm font-medium text-foreground") do %>
            Fim de semana
          <% end %>
          <%= f.select :weekend_status,
                options_for_select([["Todos", ""], ["Habilitados", "enabled"], ["Desabilitados", "disabled"]], params[:weekend_status]),
                {},
                { id: "weekend_status", class: "flex h-11 w-full rounded-md border border-border/80 bg-white px-3 py-2 text-sm text-foreground shadow-none outline-none transition-[color,box-shadow] focus-visible:border-ring focus-visible:ring-2 focus-visible:ring-ring/50" } %>
        <% end %>

        <div class="flex flex-col gap-3 sm:flex-row xl:items-end xl:justify-end">
          <% if active_filters.positive? %>
            <%= link_to manager_team_members_path, class: "inline-flex h-11 items-center justify-center rounded-md border border-border bg-white px-4 text-sm font-medium text-foreground transition-colors hover:bg-accent" do %>
              Limpar
            <% end %>
          <% end %>

          <%= render RubyUI::Button.new(type: :submit, class: "h-11 px-5 text-sm font-semibold shadow-sm") do %>
            Aplicar filtros
          <% end %>
        </div>
      <% end %>
    <% end %>
  <% end %>

  <%= render RubyUI::Card.new(class: "border-white/80 bg-white/92 shadow-[0_18px_45px_rgba(48,45,74,0.08)] overflow-hidden") do %>
    <% if @users.empty? %>
      <div class="px-6 py-14 text-center sm:px-8">
        <div class="mx-auto mb-5 inline-flex h-16 w-16 items-center justify-center rounded-full bg-secondary text-secondary-foreground">
          <i class="fas fa-users text-2xl"></i>
        </div>
        <h3 class="text-lg font-semibold text-foreground">Nenhum usuario encontrado</h3>
        <p class="mx-auto mt-2 max-w-md text-sm leading-6 text-muted-foreground">
          Tente ajustar os filtros para encontrar os integrantes da equipe que voce procura.
        </p>
      </div>
    <% else %>
      <div class="flex flex-col gap-3 border-b border-border/70 px-6 py-5 sm:px-8 lg:flex-row lg:items-center lg:justify-between">
        <div class="space-y-1">
          <h2 class="text-base font-semibold tracking-tight text-foreground">Liberacao de fim de semana</h2>
          <p class="text-sm text-muted-foreground">
            Ative apenas para quem precisa registrar ou ajustar ponto aos sabados e domingos.
          </p>
        </div>
        <p class="text-sm text-muted-foreground lg:max-w-xs lg:text-right">
          Revise a pessoa e confirme a permissao no mesmo bloco.
        </p>
      </div>

      <div class="divide-y divide-border/70">
        <% @users.each do |user| %>
          <div class="px-6 py-5 sm:px-8">
            <div class="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
              <div class="flex min-w-0 items-start gap-4">
                <div class="flex h-12 w-12 flex-none items-center justify-center rounded-full bg-secondary text-secondary-foreground">
                  <i class="fas fa-user"></i>
                </div>

                <div class="min-w-0 space-y-2">
                  <div class="space-y-1">
                    <h3 class="text-lg font-semibold tracking-tight text-foreground">
                      <%= user.name %>
                    </h3>
                    <p class="text-sm text-muted-foreground"><%= user.email %></p>
                  </div>

                  <div class="flex flex-wrap items-center gap-x-3 gap-y-2 text-sm text-muted-foreground">
                    <span class="inline-flex items-center gap-2 rounded-full bg-secondary/80 px-3 py-1 text-secondary-foreground">
                      <i class="fas fa-building text-xs"></i>
                      <%= user.department.presence || "Sem departamento" %>
                    </span>
                    <span class="inline-flex items-center gap-2 rounded-full bg-secondary/80 px-3 py-1 text-secondary-foreground">
                      <i class="fas fa-briefcase text-xs"></i>
                      <%= user.position.presence || "Sem funcao" %>
                    </span>
                    <span class="inline-flex items-center gap-2 rounded-full bg-secondary/80 px-3 py-1 text-secondary-foreground">
                      <i class="fas fa-id-badge text-xs"></i>
                      <%= user.employee_id.presence || "Sem matricula" %>
                    </span>
                  </div>
                </div>
              </div>

              <div class="flex flex-col gap-2 rounded-2xl border border-border/70 bg-secondary/10 px-4 py-3 xl:min-w-[250px] xl:items-end">
                <div class="flex w-full flex-col gap-3 sm:flex-row sm:items-center sm:justify-between xl:justify-end">
                  <span class="text-xs font-semibold uppercase tracking-[0.12em] text-muted-foreground">
                    Registro em fim de semana
                  </span>

                  <label class="inline-flex items-center gap-3">
                  <input type="checkbox"
                         class="peer sr-only"
                         data-weekend-toggle-target="checkbox"
                         data-action="change->weekend-toggle#toggle"
                         data-user-id="<%= user.id %>"
                         data-toggle-url="<%= toggle_weekend_registration_manager_team_member_path(user) %>"
                         <%= "checked" if user.weekend_registration_allowed %>>
                    <span class="relative h-6 w-11 rounded-full bg-muted transition-colors after:absolute after:left-[2px] after:top-[2px] after:h-5 after:w-5 after:rounded-full after:bg-white after:transition-transform peer-checked:bg-primary peer-checked:after:translate-x-full"></span>
                    <span class="text-sm font-medium text-foreground" data-weekend-toggle-target="label" data-user-id="<%= user.id %>">
                      <%= user.weekend_registration_allowed ? "Habilitado" : "Desabilitado" %>
                    </span>
                  </label>
                </div>

                <p class="text-sm text-muted-foreground xl:text-right" data-weekend-toggle-target="description" data-user-id="<%= user.id %>">
                  <%= user.weekend_registration_allowed ? "Pode registrar ponto e ajustes no fim de semana." : "Nao pode registrar ponto no fim de semana." %>
                </p>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <% if @users.total_pages > 1 %>
        <div class="flex flex-col gap-4 border-t border-border/70 px-6 py-5 text-sm text-muted-foreground sm:px-8 lg:flex-row lg:items-center lg:justify-between">
          <p>
            Mostrando <span class="font-medium text-foreground"><%= @users.offset_value + 1 %></span> a
            <span class="font-medium text-foreground"><%= [@users.offset_value + @users.limit_value, @users.total_count].min %></span>
            de <span class="font-medium text-foreground"><%= @users.total_count %></span> usuarios.
          </p>
          <%= paginate @users %>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>
