<%= link_to_unless current_page.first?, raw('<i class="fas fa-chevron-left text-[10px]"></i><span>Anterior</span>'), url, rel: "prev", remote: remote, class: "inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-border/80 bg-white px-3 text-sm font-medium text-foreground transition hover:bg-accent" do %>
  <span class="inline-flex h-10 items-center justify-center gap-2 rounded-lg border border-border/60 bg-white/60 px-3 text-sm font-medium text-muted-foreground">
    <i class="fas fa-chevron-left text-[10px]"></i>
    <span>Anterior</span>
  </span>
<% end %>
